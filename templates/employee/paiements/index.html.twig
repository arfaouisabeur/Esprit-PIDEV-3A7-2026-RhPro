{% extends 'base.html.twig' %}

{% block body %}
<div class="payment-page">

    <!-- 🔥 BACKGROUND EFFECT -->
    <div class="bg-shape shape1"></div>
    <div class="bg-shape shape2"></div>

    <div class="container py-5 position-relative">

        <!-- HEADER -->
        <div class="mb-5">
            <h1 class="title">💳 My Payments</h1>
            <p class="subtitle">View your salaries and bonuses</p>
        </div>

        <!-- CARDS -->
        <div class="row g-4">

            <!-- SALARY -->
            <div class="col-md-6">
                <a href="{{ path('app_employee_salaire_index') }}" class="text-decoration-none">
                    <div class="ultra-card gradient-card p-4 h-100">
                        <div class="icon">💰</div>
                        <h4 class="mt-4">My Salary</h4>
                        <p>Check your monthly salary</p>
                    </div>
                </a>
            </div>

            <!-- BONUSES -->
            <div class="col-md-6">
                <a href="{{ path('app_employee_prime_index') }}" class="text-decoration-none">
                    <div class="ultra-card p-4 h-100">
                        <div class="icon alt">🎁</div>
                        <h4 class="mt-4">My Bonuses</h4>
                        <p>View your bonuses history</p>
                    </div>
                </a>
            </div>

        </div>

    </div>
</div>

<style>

/* 🌌 BACKGROUND */
.payment-page {
    min-height: 100vh;
    background: #ffffff;
    position: relative;
    overflow: hidden;
}

/* 🔥 FLOATING SHAPES */
.bg-shape {
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.4;
    animation: float 10s infinite alternate ease-in-out;
}

.shape1 {
    background: #a855f7;
    top: -100px;
    left: -100px;
}

.shape2 {
    background: #60a5fa;
    bottom: -100px;
    right: -100px;
    animation-delay: 2s;
}

@keyframes float {
    from { transform: translateY(0px); }
    to { transform: translateY(40px); }
}

/* 🧠 HEADER */
.title {
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: -0.5px;
}

.subtitle {
    color: #6b7280;
    font-size: 1rem;
}

/* 💎 CARD */
.ultra-card {
    border-radius: 24px;
    background: rgba(255,255,255,0.75);
    backdrop-filter: blur(16px);
    box-shadow: 0 20px 50px rgba(0,0,0,0.06);
    transition: all 0.35s ease;
    position: relative;
    overflow: hidden;
}

/* ✨ LIGHT EFFECT */
.ultra-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent, rgba(255,255,255,0.6), transparent);
    opacity: 0;
    transition: 0.4s;
}

.ultra-card:hover::before {
    opacity: 1;
}

/* 🔥 HOVER */
.ultra-card:hover {
    transform: translateY(-12px) scale(1.02);
    box-shadow: 0 30px 80px rgba(123, 47, 247, 0.25);
}

/* 💜 GRADIENT */
.gradient-card {
    background: linear-gradient(135deg, #7b2ff7, #a044ff);
    color: white;
}

.gradient-card p {
    color: rgba(255,255,255,0.85);
}

/* ICON */
.icon {
    width: 65px;
    height: 65px;
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    background: #f3f0ff;
}

.icon.alt {
    background: #eef2ff;
}

.gradient-card .icon {
    background: rgba(255,255,255,0.2);
}

/* REMOVE LINK COLOR */
a {
    color: inherit !important;
}

</style>

{% endblock %}