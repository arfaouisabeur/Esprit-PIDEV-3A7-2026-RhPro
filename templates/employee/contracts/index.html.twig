{% extends 'base.html.twig' %}

{% block body %}
<div class="container py-5">

    <!-- 🔥 HEADER -->
    <div class="mb-5">
        <div class="header-block">
            <div class="header-icon">📄</div>
            <div>
                <h1 class="header-title">My Contracts</h1>
                <p class="header-subtitle">View your employment contracts</p>
            </div>
        </div>
    </div>

    <!-- CONTRACTS -->
    {% for contract in contracts %}

        <div class="contract-card mb-4">

            <!-- HEADER -->
            <div class="contract-header d-flex justify-content-between align-items-center">

                <div>
                    <h5 class="fw-bold mb-1">
                        {{ contract.type ?? 'Contrat de travail' }}
                    </h5>
                    <small class="text-muted">
                        {{ contract.employe.user.fullName }}
                    </small>
                </div>

                <span class="status-badge 
                    {% if contract.dateFin and contract.dateFin < "now"|date('Y-m-d') %}
                        expired
                    {% else %}
                        active
                    {% endif %}
                ">
                    {% if contract.dateFin and contract.dateFin < "now"|date('Y-m-d') %}
                        Expired
                    {% else %}
                        Active
                    {% endif %}
                </span>

            </div>

            <hr>

            <!-- BODY -->
            <div class="row g-3">

                <div class="col-md-6">
                    <p class="info"><strong>📅 Start:</strong> {{ contract.dateDebut|date('d/m/Y') }}</p>
                    <p class="info"><strong>📅 End:</strong> {{ contract.dateFin ? contract.dateFin|date('d/m/Y') : 'Indefinite' }}</p>
                </div>

                <div class="col-md-6">
                    <p class="info">
                        <strong>💰 Salary:</strong>
                        <span class="salary">
                            {{ contract.salaireBase }} DT
                        </span>
                    </p>

                    <p class="info">
                        <strong>📝 Description:</strong><br>
                        {{ contract.description ?: 'No description' }}
                    </p>
                </div>

            </div>

            <!-- ACTION -->
            <div class="text-end mt-4">
                <a href="{{ path('app_employee_contract_pdf', {'id': contract.id}) }}"
                   class="btn btn-main">
                    📥 Download PDF
                </a>
            </div>

        </div>

    {% else %}
        <div class="empty-state">
            📄 No contracts found
        </div>
    {% endfor %}

</div>

<style>

/* 🌸 BACKGROUND FIX */
body {
    background: #f6f4fb !important;
}

/* 🔥 HEADER */
.header-block {
    display: flex;
    align-items: center;
    gap: 15px;
}

.header-icon {
    width: 55px;
    height: 55px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
    background: linear-gradient(135deg, #7b2ff7, #a044ff);
    color: white;
}

.header-title {
    font-size: 2rem;
    font-weight: 800;
    margin: 0;
    background: linear-gradient(135deg, #7b2ff7, #a044ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.header-subtitle {
    margin: 0;
    color: #6b7280;
}

/* 💎 CARD */
.contract-card {
    background: white;
    border-radius: 20px;
    padding: 25px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.05);
    transition: 0.3s;
}

.contract-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 30px 70px rgba(123,47,247,0.15);
}

/* STATUS */
.status-badge {
    padding: 6px 14px;
    border-radius: 20px;
    font-weight: 600;
}

.status-badge.active {
    background: #dcfce7;
    color: #16a34a;
}

.status-badge.expired {
    background: #fee2e2;
    color: #dc2626;
}

/* INFO */
.info {
    margin-bottom: 8px;
    color: #555;
}

/* SALARY */
.salary {
    font-weight: 700;
    color: #16a34a;
}

/* BUTTON */
.btn-main {
    background: linear-gradient(135deg, #7b2ff7, #a044ff);
    border: none;
    color: white;
    border-radius: 25px;
    padding: 10px 20px;
    font-weight: 600;
    box-shadow: 0 10px 25px rgba(123,47,247,0.3);
}

/* EMPTY STATE */
.empty-state {
    text-align: center;
    padding: 40px;
    color: #6b7280;
}

</style>

{% endblock %}