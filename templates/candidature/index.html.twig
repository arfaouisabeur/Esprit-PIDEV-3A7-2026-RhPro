{% extends 'base.html.twig' %}

{% block title %}Candidature index{% endblock %}

{% block body %}
    <h1>Candidature index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Date_candidature</th>
                <th>Statut</th>
                <th>Cv_path</th>
                <th>Cv_original_name</th>
                <th>Cv_size</th>
                <th>Cv_uploaded_at</th>
                <th>Match_score</th>
                <th>Match_updated_at</th>
                <th>Signature_request_id</th>
                <th>Contract_status</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for candidature in candidatures %}
            <tr>
                <td>{{ candidature.id }}</td>
                <td>{{ candidature.dateCandidature ? candidature.dateCandidature|date('Y-m-d') : '' }}</td>
                <td>{{ candidature.statut }}</td>
                <td>{{ candidature.cvPath }}</td>
                <td>{{ candidature.cvOriginalName }}</td>
                <td>{{ candidature.cvSize }}</td>
                <td>{{ candidature.cvUploadedAt ? candidature.cvUploadedAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ candidature.matchScore }}</td>
                <td>{{ candidature.matchUpdatedAt ? candidature.matchUpdatedAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ candidature.signatureRequestId }}</td>
                <td>{{ candidature.contractStatus }}</td>
                <td>
                    <a href="{{ path('app_candidature_show', {'id': candidature.id}) }}">show</a>
                    <a href="{{ path('app_candidature_edit', {'id': candidature.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="12">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_candidature_new') }}">Create new</a>
{% endblock %}
