{% extends 'base.html.twig' %}
{% block title %}Détail candidature{% endblock %}

{% block styles %}
<style>
    body { background:#F7F4FB !important; }
    .pg { max-width:1060px; margin:0 auto; padding:36px 24px 60px; }
    .btn-op { display:inline-flex; align-items:center; gap:7px; padding:9px 18px; border-radius:99px; background:transparent; color:#6D2269; border:1.5px solid #6D2269; font-size:13px; font-weight:600; text-decoration:none; transition:all .22s; }
    .btn-op:hover { background:#6D2269; color:#fff; }
    .hero { background:linear-gradient(135deg,#4E1A4B,#6D2269); border-radius:18px; padding:28px 32px; color:#fff; margin-bottom:22px; display:flex; align-items:center; gap:18px; position:relative; overflow:hidden; }
    .hero::after { content:''; position:absolute; top:-30px; right:-30px; width:140px; height:140px; background:rgba(255,255,255,0.05); border-radius:50%; }
    .hero-av { width:60px; height:60px; background:rgba(255,255,255,0.18); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:22px; font-weight:700; flex-shrink:0; }
    .hero-name { font-size:20px; font-weight:700; margin-bottom:4px; }
    .hero-sub  { font-size:14px; opacity:.8; }
    .layout { display:grid; grid-template-columns:1fr 300px; gap:20px; align-items:start; }
    .cs { background:#fff; border-radius:14px; box-shadow:0 2px 12px rgba(109,34,105,0.08); border:1px solid rgba(109,34,105,0.07); overflow:hidden; margin-bottom:18px; }
    .csh { padding:14px 20px; border-bottom:1px solid rgba(109,34,105,0.07); font-size:14px; font-weight:700; color:#4E1A4B; display:flex; align-items:center; gap:8px; }
    .csb { padding:18px 20px; }
    .info-r { display:flex; align-items:center; gap:12px; padding:11px 18px; border-bottom:1px solid rgba(109,34,105,0.05); }
    .info-r:last-child { border-bottom:none; }
    .info-ico { width:32px; height:32px; background:#F7F4FB; border-radius:8px; display:flex; align-items:center; justify-content:center; color:#6D2269; font-size:14px; flex-shrink:0; }
    .info-lb { font-size:10px; color:#6c757d; font-weight:700; text-transform:uppercase; letter-spacing:.5px; }
    .info-v  { font-size:13px; font-weight:600; }
    .bs { display:inline-flex; align-items:center; gap:4px; padding:5px 12px; border-radius:99px; font-size:12px; font-weight:600; }
    .bs-wait { background:#fff8e1; color:#f59e0b; }
    .bs-ok   { background:#e8f5e9; color:#22c55e; }
    .bs-no   { background:#fce8e8; color:#ef4444; }
    .bs-rev  { background:#ede9fe; color:#7c3aed; }
    .cv-pill { display:inline-flex; align-items:center; gap:6px; padding:8px 16px; border-radius:99px; background:rgba(109,34,105,0.07); color:#6D2269; font-size:13px; font-weight:600; text-decoration:none; transition:all .22s; }
    .cv-pill:hover { background:#6D2269; color:#fff; }
    /* ── Widget Analyse IA ── */
    .ai-btn { width:100%; padding:11px; border-radius:99px; background:linear-gradient(135deg,#6D2269,#8B3A86); color:#fff; font-size:13px; font-weight:600; border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:8px; transition:all .22s; margin-bottom:10px; }
    .ai-btn:hover { transform:translateY(-2px); box-shadow:0 6px 18px rgba(109,34,105,.35); }
    .ai-btn:disabled { opacity:.6; cursor:not-allowed; transform:none; }
    .score-ring { position:relative; width:80px; height:80px; margin:6px auto 10px; }
    .score-ring svg { transform:rotate(-90deg); }
    .score-ring-val { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); font-size:18px; font-weight:700; }
    .skill-tag { display:inline-block; padding:3px 10px; background:rgba(109,34,105,.09); color:#6D2269; border-radius:99px; font-size:11px; font-weight:600; margin:2px; }
    .ai-box { background:#F7F4FB; border:1px solid rgba(109,34,105,.12); border-radius:10px; padding:12px 14px; font-size:12px; color:#4E1A4B; line-height:1.7; white-space:pre-line; margin-top:10px; }
    .ai-err { background:#fce8e8; color:#ef4444; border-radius:8px; padding:8px 12px; font-size:12px; margin-top:8px; }
    .stat-btn { display:inline-flex; align-items:center; gap:6px; padding:9px 16px; border-radius:99px; font-size:13px; font-weight:600; border:1.5px solid; cursor:pointer; transition:all .22s; background:transparent; }
    .sb-wait { color:#f59e0b; border-color:#f59e0b; } .sb-wait:hover { background:#f59e0b; color:#fff; }
    .sb-int  { color:#7c3aed; border-color:#7c3aed; } .sb-int:hover { background:#7c3aed; color:#fff; }
    .sb-ok   { color:#22c55e; border-color:#22c55e; } .sb-ok:hover { background:#22c55e; color:#fff; }
    .sb-no   { color:#ef4444; border-color:#ef4444; } .sb-no:hover { background:#ef4444; color:#fff; }
    @media(max-width:800px){ .layout{grid-template-columns:1fr;} }
</style>
{% endblock %}

{% block body %}
<div class="pg">

    <div style="margin-bottom:20px;">
        <a href="{{ path('app_candidature_index') }}" class="btn-op"><i class="bi bi-arrow-left"></i> Retour à la liste</a>
    </div>

    <div class="hero">
        <div class="hero-av">
            {% if candidature.candidat is not null and candidature.candidat.user is not null %}
                {{ candidature.candidat.user.prenom|first|upper }}{{ candidature.candidat.user.nom|first|upper }}
            {% else %}?{% endif %}
        </div>
        <div>
            <div class="hero-name">
                {% if candidature.candidat is not null and candidature.candidat.user is not null %}
                    {{ candidature.candidat.user.nom }} {{ candidature.candidat.user.prenom }}
                {% else %}Candidat #{{ candidature.id }}{% endif %}
            </div>
            <div class="hero-sub">
                <i class="bi bi-envelope" style="margin-right:5px;"></i>
                {% if candidature.candidat is not null and candidature.candidat.user is not null %}
                    {{ candidature.candidat.user.email }}
                {% endif %}
            </div>
        </div>
    </div>

    <div class="layout">
        <div>
            {# Offre liée #}
            <div class="cs">
                <div class="csh"><i class="bi bi-briefcase" style="color:#6D2269;"></i> Offre concernée</div>
                <div class="csb" style="display:flex;align-items:center;gap:14px;">
                    <div style="width:46px;height:46px;background:#F7F4FB;border-radius:10px;display:flex;align-items:center;justify-content:center;color:#6D2269;font-size:20px;flex-shrink:0;">
                        <i class="bi bi-briefcase-fill"></i>
                    </div>
                    <div style="flex:1;">
                        <div style="font-weight:700;font-size:15px;color:#4E1A4B;">
                            {% if candidature.offreEmploi is not null %}{{ candidature.offreEmploi.titre }}{% else %}—{% endif %}
                        </div>
                        <div style="font-size:13px;color:#6c757d;margin-top:3px;">
                            {% if candidature.offreEmploi is not null %}
                                {{ candidature.offreEmploi.typeContrat }} — {{ candidature.offreEmploi.localisation }}
                            {% endif %}
                        </div>
                    </div>
                    {% if candidature.offreEmploi is not null %}
                    <a href="{{ path('app_offre_emploi_show', {'id': candidature.offreEmploi.id}) }}" class="btn-op" style="padding:7px 14px;font-size:12px;">
                        Voir l'offre
                    </a>
                    {% endif %}
                </div>
            </div>

            {# Lettre de motivation #}
            {% if candidature.lettreMotivation is defined and candidature.lettreMotivation %}
            <div class="cs">
                <div class="csh"><i class="bi bi-chat-text" style="color:#6D2269;"></i> Lettre de motivation</div>
                <div class="csb" style="font-size:15px;line-height:1.8;color:#333;">{{ candidature.lettreMotivation|nl2br }}</div>
            </div>
            {% endif %}

            {# Changer statut #}
            <div class="cs">
                <div class="csh"><i class="bi bi-sliders" style="color:#6D2269;"></i> Changer le statut</div>
                <div class="csb">
                    <form method="post" action="{{ path('app_candidature_statut', {'id': candidature.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('statut'~candidature.id) }}">
                        <div style="display:flex;gap:8px;flex-wrap:wrap;">
                            <button type="submit" name="statut" value="en_attente" class="stat-btn sb-wait"><i class="bi bi-hourglass-split"></i> En attente</button>
                            <button type="submit" name="statut" value="entretien"  class="stat-btn sb-int"><i class="bi bi-camera-video"></i> Entretien</button>
                            <button type="submit" name="statut" value="acceptee"   class="stat-btn sb-ok"><i class="bi bi-check-circle"></i> Accepter</button>
                            <button type="submit" name="statut" value="refusee"    class="stat-btn sb-no"><i class="bi bi-x-circle"></i> Refuser</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div>
            <div class="cs">
                <div class="csh"><i class="bi bi-info-circle" style="color:#6D2269;"></i> Résumé</div>

                <div class="info-r">
                    <div class="info-ico"><i class="bi bi-calendar3"></i></div>
                    <div>
                        <div class="info-lb">Date de candidature</div>
                        <div class="info-v">{{ candidature.dateCandidature ? candidature.dateCandidature|date('d/m/Y') : '—' }}</div>
                    </div>
                </div>

                <div class="info-r">
                    <div class="info-ico"><i class="bi bi-flag-fill"></i></div>
                    <div>
                        <div class="info-lb">Statut actuel</div>
                        <div class="info-v">
                            {% set sl = (candidature.statut ?? '')|lower|replace({' ':'_','é':'e'}) %}
                            {% if sl in ['acceptee','accepted'] %}
                                <span class="bs bs-ok"><i class="bi bi-check-circle-fill"></i>Acceptée</span>
                            {% elseif sl in ['refusee','rejected'] %}
                                <span class="bs bs-no"><i class="bi bi-x-circle-fill"></i>Refusée</span>
                            {% elseif sl in ['entretien','interview'] %}
                                <span class="bs bs-rev"><i class="bi bi-camera-video-fill"></i>Entretien</span>
                            {% else %}
                                <span class="bs bs-wait"><i class="bi bi-hourglass-split"></i>En attente</span>
                            {% endif %}
                        </div>
                    </div>
                </div>

                {% if candidature.matchScore is not null %}
                <div class="info-r">
                    <div class="info-ico"><i class="bi bi-bar-chart-fill"></i></div>
                    <div>
                        <div class="info-lb">Score de matching</div>
                        <div class="info-v">
                            <span style="background:linear-gradient(135deg,#6D2269,#8B3A86);color:#fff;border-radius:99px;padding:3px 12px;font-size:12px;font-weight:700;">
                                {{ candidature.matchScore }}%
                            </span>
                        </div>
                    </div>
                </div>
                {% endif %}

                <div class="info-r">
                    <div class="info-ico"><i class="bi bi-file-earmark-pdf-fill"></i></div>
                    <div>
                        <div class="info-lb">CV fourni</div>
                        <div class="info-v">
                            {% if candidature.cvPath %}
                                <a href="{{ asset('uploads/cv/'~candidature.cvPath) }}" target="_blank" class="cv-pill">
                                    <i class="bi bi-file-earmark-pdf-fill"></i>
                                    {{ candidature.cvOriginalName ?? 'Télécharger CV' }}
                                </a>
                            {% else %}Non fourni{% endif %}
                        </div>
                    </div>
                </div>

                {% if candidature.contractStatus is defined and candidature.contractStatus %}
                <div class="info-r">
                    <div class="info-ico"><i class="bi bi-file-earmark-check-fill"></i></div>
                    <div>
                        <div class="info-lb">Statut contrat</div>
                        <div class="info-v">{{ candidature.contractStatus }}</div>
                    </div>
                </div>
                {% endif %}
            </div>
        {# ── Widget Analyse IA ───────────────────────────────────────── #}
        <div class="cs" id="ai-widget">
            <div class="csh">
                <i class="bi bi-cpu-fill" style="color:#6D2269;"></i>
                Analyse IA du CV
            </div>
            <div class="csb" id="ai-content">

                {% if candidature.cvPath %}
                <button class="ai-btn" id="btn-analyse" onclick="lancerAnalyse()">
                    <i class="bi bi-stars"></i>
                    {% if candidature.matchScore is not null %}Relancer l'analyse{% else %}Analyser le CV avec l'IA{% endif %}
                </button>
                {% else %}
                <div style="text-align:center;color:#9c8ab0;font-size:13px;padding:12px;">
                    <i class="bi bi-file-earmark-x" style="font-size:22px;display:block;margin-bottom:6px;"></i>
                    Aucun CV disponible
                </div>
                {% endif %}

                {# Résultats existants #}
                {% if candidature.matchScore is not null %}
                <div id="existing-results">
                    {% set sc = candidature.matchScore %}
                    {% set col = sc >= 75 ? '#22c55e' : (sc >= 50 ? '#f59e0b' : '#ef4444') %}
                    {% set circ = (sc * 2.136)|round %}
                    <div class="score-ring">
                        <svg width="80" height="80" viewBox="0 0 80 80">
                            <circle cx="40" cy="40" r="34" fill="none" stroke="#F0E6FF" stroke-width="8"/>
                            <circle cx="40" cy="40" r="34" fill="none" stroke="{{ col }}" stroke-width="8"
                                    stroke-dasharray="{{ circ }} 213.6" stroke-linecap="round"/>
                        </svg>
                        <div class="score-ring-val" style="color:{{ col }};">{{ sc }}%</div>
                    </div>
                    <div style="text-align:center;font-size:11px;color:#6c757d;margin-bottom:10px;">Score de matching</div>

                    {% if candidature.cvSkills %}
                    <div style="font-size:10px;color:#6c757d;font-weight:700;text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;">Compétences</div>
                    <div>
                        {% for skill in candidature.cvSkills|split(',') %}
                            {% if skill|trim %}<span class="skill-tag">{{ skill|trim }}</span>{% endif %}
                        {% endfor %}
                    </div>
                    {% endif %}

                    {% if candidature.aiAnalysis %}
                    <div class="ai-box" style="margin-top:10px;">{{ candidature.aiAnalysis }}</div>
                    {% endif %}

                    {% if candidature.matchUpdatedAt %}
                    <div style="text-align:center;font-size:10px;color:#9c8ab0;margin-top:8px;">
                        <i class="bi bi-clock"></i> {{ candidature.matchUpdatedAt|date('d/m/Y H:i') }}
                    </div>
                    {% endif %}
                </div>
                {% endif %}

                {# Zone résultats dynamiques #}
                <div id="ai-live" style="display:none;">
                    <div id="ai-loading" style="display:none;text-align:center;padding:16px;color:#9c8ab0;font-size:13px;">
                        <div class="spinner-border spinner-border-sm" style="color:#6D2269;width:18px;height:18px;margin-right:8px;"></div>
                        Analyse en cours...
                    </div>
                    <div id="ai-result"></div>
                    <div id="ai-error" class="ai-err" style="display:none;"></div>
                </div>

            </div>
        </div>

        </div>
    </div>

</div>
{% endblock %}
{% block javascripts %}
{{ parent() }}
<script>
const ANALYSE_URL = "{{ path('candidature_analyse_cv', {'id': candidature.id}) }}";
const CSRF_TOKEN  = "{{ csrf_token('analyse_cv_' ~ candidature.id) }}";

function lancerAnalyse() {
    const btn      = document.getElementById('btn-analyse');
    const live     = document.getElementById('ai-live');
    const loading  = document.getElementById('ai-loading');
    const result   = document.getElementById('ai-result');
    const errBox   = document.getElementById('ai-error');
    const existing = document.getElementById('existing-results');

    btn.disabled     = true;
    btn.innerHTML    = '<span class="spinner-border spinner-border-sm" style="color:#fff;width:14px;height:14px;margin-right:6px;"></span> Analyse en cours...';
    live.style.display    = 'block';
    loading.style.display = 'block';
    result.innerHTML      = '';
    errBox.style.display  = 'none';
    if (existing) existing.style.display = 'none';

    fetch(ANALYSE_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify({ _token: CSRF_TOKEN })
    })
    .then(r => r.json())
    .then(data => {
        loading.style.display = 'none';
        if (!data.success) {
            errBox.textContent   = '❌ ' + (data.error || 'Erreur inconnue');
            errBox.style.display = 'block';
            btn.disabled         = false;
            btn.innerHTML        = '<i class="bi bi-stars"></i> Réessayer';
            return;
        }

        const sc    = data.score;
        const col   = sc >= 75 ? '#22c55e' : sc >= 50 ? '#f59e0b' : '#ef4444';
        const label = sc >= 75 ? 'Excellent' : sc >= 50 ? 'Bon matching' : sc >= 30 ? 'Partiel' : 'Faible';
        const circ  = 2 * Math.PI * 34;
        const dash  = (sc * circ / 100).toFixed(1);

        const skills = (data.skills || '').split(',').map(s => s.trim()).filter(Boolean);
        const skillsHtml = skills.map(s => `<span class="skill-tag">${s}</span>`).join('');
        const analysisHtml = data.analysis
            ? `<div class="ai-box">${data.analysis.replace(/\n/g,'<br>')}</div>` : '';

        result.innerHTML = `
            <div class="score-ring">
                <svg width="80" height="80" viewBox="0 0 80 80">
                    <circle cx="40" cy="40" r="34" fill="none" stroke="#F0E6FF" stroke-width="8"/>
                    <circle cx="40" cy="40" r="34" fill="none" stroke="${col}" stroke-width="8"
                            stroke-dasharray="${dash} ${circ.toFixed(1)}"
                            stroke-linecap="round" transform="rotate(-90 40 40)"/>
                </svg>
                <div class="score-ring-val" style="color:${col};">${sc}%</div>
            </div>
            <div style="text-align:center;font-size:11px;color:#6c757d;margin-bottom:10px;">${label}</div>
            ${skills.length ? `<div style="font-size:10px;color:#6c757d;font-weight:700;text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;">Compétences détectées</div><div>${skillsHtml}</div>` : ''}
            ${analysisHtml}
            <div style="text-align:center;font-size:10px;color:#9c8ab0;margin-top:8px;"><i class="bi bi-clock"></i> À l'instant</div>
        `;

        btn.disabled  = false;
        btn.innerHTML = '<i class="bi bi-arrow-clockwise"></i> Relancer';
    })
    .catch(err => {
        loading.style.display = 'none';
        errBox.textContent    = '❌ Erreur réseau : ' + err.message;
        errBox.style.display  = 'block';
        btn.disabled          = false;
        btn.innerHTML         = '<i class="bi bi-stars"></i> Réessayer';
    });
}
</script>
{% endblock %}
