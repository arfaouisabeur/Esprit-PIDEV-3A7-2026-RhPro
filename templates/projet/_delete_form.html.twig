<form method="post" action="{{ path('app_projet_delete', {'id': projet.id}) }}" 
      onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer définitivement ce projet ?');" 
      style="display: inline-block;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ projet.id) }}">
    <button class="btn btn-outline-danger" style="border-radius: 12px; padding: 0.5rem 1.25rem; font-weight: 600; transition: all 0.3s ease; border-width: 2px;">
        <i class="bi bi-trash3-fill me-2"></i> Supprimer
    </button>
</form>