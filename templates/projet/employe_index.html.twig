{% extends 'base.html.twig' %}
{% block title %}Tableau de Bord Projets | RH Pro{% endblock %}

{% block styles %}
<style>
    :root {
        --page-bg: #f8fafc;
        --card-white: #ffffff;
        --card-border: #e2e8f0;
        --accent-purple: #6b2d8b;
        --accent-purple-light: #9333ea;
        --text-dark: #1e293b;
        --text-muted: #64748b;
    }

    body, html, main { background-color: var(--page-bg) !important; color: var(--text-dark); }
    body { font-family: 'Inter', sans-serif; min-height: 100vh; }

    .dashboard-container {
        padding: 4rem 2rem;
        max-width: 1400px;
        margin: 0 auto;
        animation: slideIn 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    @keyframes slideIn { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }

    /* Stats */
    .summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.2rem; margin-bottom: 3.5rem; }
    .summary-card {
        background: var(--card-white);
        border-radius: 20px; padding: 1.6rem 1.8rem;
        display: flex; flex-direction: column; gap: 14px;
        box-shadow: 0 4px 20px rgba(107,45,139,.07);
        border: 1px solid transparent;
        transition: all .25s; position: relative; overflow: hidden;
    }
    .summary-card::after {
        content: ''; position: absolute; bottom: -20px; right: -20px;
        width: 80px; height: 80px; border-radius: 50%;
        background: currentColor; opacity: .05;
    }
    .summary-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(107,45,139,.13); }
    .summary-card.sc-purple { border-color: #ddd6fe; color: var(--accent-purple); }
    .summary-card.sc-green  { border-color: #a7f3d0; color: #059669; }
    .summary-card.sc-amber  { border-color: #fde68a; color: #b45309; }
    .sum-top { display: flex; justify-content: space-between; align-items: center; }
    .sum-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; flex-shrink: 0; }
    .sc-purple .sum-icon { background: #f5f3ff; color: var(--accent-purple); }
    .sc-green  .sum-icon { background: #d1fae5; color: #059669; }
    .sc-amber  .sum-icon { background: #fef3c7; color: #b45309; }
    .sum-trend { font-size: .7rem; font-weight: 700; padding: 3px 8px; border-radius: 20px; }
    .sc-purple .sum-trend { background: #f5f3ff; color: var(--accent-purple); }
    .sc-green  .sum-trend { background: #d1fae5; color: #059669; }
    .sc-amber  .sum-trend { background: #fef3c7; color: #b45309; }
    .sum-val { font-size: 2.4rem; font-weight: 900; color: var(--text-dark); line-height: 1; }
    .sum-lbl { font-size: .72rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: .07em; }

    /* Header */
    .dashboard-header { margin-bottom: 2.5rem; }
    .dashboard-header h2 { font-family: 'Playfair Display', serif; font-size: 2.5rem; font-weight: 700; color: var(--accent-purple); margin: 0; }

    /* Grid */
    .projects-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(380px, 1fr)); gap: 2.5rem; }

    /* Card */
    .premium-project-card {
        background: var(--card-white); border: 1px solid var(--card-border);
        border-radius: 24px; padding: 2.5rem;
        position: relative; transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        display: flex; flex-direction: column;
        box-shadow: 0 4px 20px rgba(0,0,0,.02);
        overflow: hidden;
    }
    .premium-project-card::before {
        content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
        background: linear-gradient(90deg, var(--accent-purple), var(--accent-purple-light));
        opacity: 0; transition: opacity .25s;
    }
    .premium-project-card:hover { transform: translateY(-8px); box-shadow: 0 25px 50px rgba(107,45,139,.1); border-color: #c4b5fd; }
    .premium-project-card:hover::before { opacity: 1; }

    /* Badge statut */
    .badge-modern { padding: 5px 13px; border-radius: 20px; font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; display: inline-flex; align-items: center; gap: 5px; }
    .badge-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
    .status-en_attente { color: #6b2d8b; background: #f5f3ff; border: 1px solid #ddd6fe; }
    .status-en_cours   { color: #b45309; background: #fef3c7; border: 1px solid #fde68a; }
    .status-termine    { color: #065f46; background: #d1fae5; border: 1px solid #a7f3d0; }
    .status-annule     { color: #b91c1c; background: #fee2e2; border: 1px solid #fecaca; }

    .p-title { font-size: 1.4rem; font-weight: 800; color: var(--text-dark); margin-bottom: 0.75rem; }
    .p-desc { color: var(--text-muted); font-size: .9rem; line-height: 1.6; margin-bottom: 2rem; height: 3.2em; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

    /* Progress */
    .p-progress-container { margin-top: auto; margin-bottom: 2rem; }
    .p-progress-meta { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: .75rem; }
    .p-progress-val { font-size: 1.4rem; font-weight: 800; color: var(--accent-purple); }
    .p-progress-bar-bg { height: 8px; background: #f1f5f9; border-radius: 10px; overflow: hidden; }
    .p-progress-bar-fill { height: 100%; background: linear-gradient(90deg, var(--accent-purple), var(--accent-purple-light)); border-radius: 10px; transition: width 1.2s ease-out; }

    /* Footer */
    .p-card-footer { display: flex; justify-content: space-between; align-items: center; padding-top: 1.5rem; border-top: 1px solid #f1f5f9; }
    .p-meta-info { font-size: .8rem; color: var(--text-muted); display: flex; flex-direction: column; gap: .25rem; font-weight: 500; }
    .p-meta-info span { display: flex; align-items: center; gap: .5rem; }
    .p-meta-info i { color: #a78bfa; }

    .p-btn-action {
        width: 44px; height: 44px; border-radius: 13px;
        display: flex; align-items: center; justify-content: center;
        background: #f5f3ff; color: var(--accent-purple);
        border: 1.5px solid #ddd6fe;
        transition: all .25s; text-decoration: none;
    }
    .p-btn-action:hover { background: var(--accent-purple); color: white; border-color: var(--accent-purple); transform: scale(1.1); }

    .empty-state { text-align: center; padding: 6rem 2rem; background: white; border-radius: 30px; border: 1px solid var(--card-border); }

    @media (max-width: 768px) { .dashboard-container { padding: 2rem 1rem; } .projects-grid { grid-template-columns: 1fr; } }
</style>
{% endblock %}

{% block body %}
<div class="dashboard-container">

    <div class="summary-grid">
        <div class="summary-card sc-purple">
            <div class="sum-top">
                <div class="sum-icon"><i class="bi bi-diagram-3-fill"></i></div>
                <span class="sum-trend">Actifs</span>
            </div>
            <div class="sum-val">{{ totalProjects }}</div>
            <div class="sum-lbl">Projets actifs</div>
        </div>
        <div class="summary-card sc-green">
            <div class="sum-top">
                <div class="sum-icon"><i class="bi bi-check-circle-fill"></i></div>
                <span class="sum-trend">✔ Done</span>
            </div>
            <div class="sum-val">{{ completedProjects }}</div>
            <div class="sum-lbl">Projets terminés</div>
        </div>
        <div class="summary-card sc-amber">
            <div class="sum-top">
                <div class="sum-icon"><i class="bi bi-list-check"></i></div>
                <span class="sum-trend">Total</span>
            </div>
            <div class="sum-val">{{ totalTasks }}</div>
            <div class="sum-lbl">Tâches assignées</div>
        </div>
    </div>

    <div class="dashboard-header">
        <h2>Mes Missions</h2>
        <p style="color:var(--text-muted);margin-top:.5rem">Vue d'ensemble de vos responsabilités opérationnelles.</p>
    </div>

    {% if projetsData is empty %}
        <div class="empty-state">
            <i class="bi bi-inbox" style="font-size:2.5rem;color:#ddd6fe;display:block;margin-bottom:1rem"></i>
            <h3 style="color:var(--text-dark);font-size:1.5rem;margin-bottom:1rem">Horizon dégagé</h3>
            <p style="color:var(--text-muted)">Vous n'avez pas encore d'assignation en cours.</p>
        </div>
    {% else %}
        <div class="projects-grid">
            {% for data in projetsData %}
            {% set projet = data.entity %}
            <div class="premium-project-card">

                <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1.5rem">
                    <span class="badge-modern status-{{ projet.statut|lower }}">
                        <span class="badge-dot"></span>
                        {{ projet.statut|replace({'_':' ','en_cours':'En cours','en_attente':'À faire','termine':'Terminé','annule':'Annulé'}) }}
                    </span>
                    <span style="font-weight:700;color:#ddd6fe;font-size:.85rem;font-family:monospace">
                        #{{ loop.index < 10 ? '0'~loop.index : loop.index }}
                    </span>
                </div>

                <h3 class="p-title">{{ projet.titre }}</h3>
                <p class="p-desc">{{ projet.description ?: 'Opération stratégique en phase de déploiement.' }}</p>

                <div class="p-progress-container">
                    <div class="p-progress-meta">
                        <span style="color:var(--text-muted);font-size:.85rem;font-weight:600">Progression</span>
                        <span class="p-progress-val">{{ data.progress }}%</span>
                    </div>
                    <div class="p-progress-bar-bg">
                        <div class="p-progress-bar-fill" style="width:{{ data.progress }}%"></div>
                    </div>
                    <div style="margin-top:.6rem;display:flex;justify-content:space-between;font-size:.72rem;font-weight:700;color:#94a3b8">
                        <span>{{ data.completedTasks }} complétées</span>
                        <span>{{ data.totalTasks }} total</span>
                    </div>
                </div>

                <div class="p-card-footer">
                    <div class="p-meta-info">
                        <span><i class="bi bi-calendar-event"></i> {{ projet.dateDebut|date('d/m/Y') }}</span>
                        <span><i class="bi bi-calendar-check"></i> {{ projet.dateFin|date('d/m/Y') }}</span>
                    </div>
                    <div class="d-flex gap-2">
                        {% if projet.isMeetingRequested %}
                            <a href="{{ path('app_projet_meeting', {'id': projet.id}) }}" class="p-btn-action" style="background:#10b981;border-color:#10b981;color:white;box-shadow:0 0 14px rgba(16,185,129,.35)" title="Rejoindre la réunion">
                                <i class="bi bi-camera-video-fill" style="font-size:1.1rem"></i>
                            </a>
                        {% else %}
                            <div class="p-btn-action" style="opacity:.35;cursor:not-allowed" title="Aucune réunion">
                                <i class="bi bi-camera-video-off" style="font-size:1.1rem"></i>
                            </div>
                        {% endif %}
                        <a href="{{ path('app_tache_par_projet', {'projetId': projet.id}) }}" class="p-btn-action" title="Voir les tâches">
                            <i class="bi bi-arrow-right-short" style="font-size:1.4rem"></i>
                        </a>
                    </div>
                </div>

            </div>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
