{% extends 'base.html.twig' %}

{% block title %}Tableau de Bord Projets | RH Pro{% endblock %}

{% block stylesheets %}
<style>
    :root {
        --page-bg: #f8fafc;
        --card-white: #ffffff;
        --card-border: #e2e8f0;
        --accent-purple: #5b2b82;
        --accent-purple-light: #7c3dac;
        --accent-gold: #b39ddb;
        --text-dark: #1e293b;
        --text-muted: #64748b;
    }

    body, html, main {
        background-color: var(--page-bg) !important;
        color: var(--text-dark);
    }

    body {
        font-family: 'Inter', sans-serif;
        min-height: 100vh;
    }

    .dashboard-container {
        padding: 4rem 2rem;
        max-width: 1400px;
        margin: 0 auto;
        animation: slideIn 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @keyframes slideIn {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* --- TOP STATS --- */
    .summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
        margin-bottom: 4rem;
    }

    .summary-card {
        background: var(--card-white);
        border: 1px solid var(--card-border);
        border-radius: 20px;
        padding: 2rem;
        display: flex;
        align-items: center;
        gap: 1.25rem;
        box-shadow: 0 10px 30px rgba(91, 43, 130, 0.03);
        transition: all 0.3s ease;
    }

    .summary-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 40px rgba(91, 43, 130, 0.08);
        border-color: var(--accent-purple-light);
    }

    .sum-icon {
        width: 56px; height: 56px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        background: #f1f5f9;
        color: var(--accent-purple);
    }

    .sum-info h4 { font-size: 0.8rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin: 0; }
    .sum-info span { font-size: 1.8rem; font-weight: 800; color: var(--text-dark); }

    /* --- PROJECTS SECTION --- */
    .dashboard-header {
        margin-bottom: 2.5rem;
    }

    .dashboard-header h2 {
        font-family: 'Playfair Display', serif;
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--accent-purple);
        margin: 0;
    }

    .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
        gap: 2.5rem;
    }

    .premium-project-card {
        background: var(--card-white);
        border: 1px solid var(--card-border);
        border-radius: 24px;
        padding: 2.5rem;
        position: relative;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        display: flex;
        flex-direction: column;
        box-shadow: 0 4px 20px rgba(0,0,0,0.02);
    }

    .premium-project-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 25px 50px rgba(91, 43, 130, 0.08);
        border-color: var(--accent-purple-light);
    }

    .badge-modern {
        padding: 0.5rem 1rem;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.02em;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
    }

    .status-en_attente { color: #854d0e; background: #fefce8; border-color: #fef08a; }
    .status-en_cours   { color: #1e40af; background: #eff6ff; border-color: #bfdbfe; }
    .status-termine    { color: #166534; background: #f0fdf4; border-color: #bbf7d0; }

    .p-title { font-size: 1.5rem; font-weight: 800; color: var(--text-dark); margin-bottom: 0.75rem; }
    .p-desc { color: var(--text-muted); font-size: 0.95rem; line-height: 1.6; margin-bottom: 2rem; height: 3.2em; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

    /* --- PROGRESS AREA --- */
    .p-progress-container { margin-top: auto; margin-bottom: 2rem; }
    .p-progress-meta { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 0.75rem; }
    .p-progress-val { font-size: 1.4rem; font-weight: 800; color: var(--accent-purple); }
    .p-progress-bar-bg { height: 8px; background: #f1f5f9; border-radius: 10px; overflow: hidden; }
    .p-progress-bar-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--accent-purple), var(--accent-purple-light));
        border-radius: 10px;
        transition: width 1.2s ease-out;
    }

    .p-card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 1.5rem;
        border-top: 1px solid #f1f5f9;
    }

    .p-meta-info { font-size: 0.8rem; color: var(--text-muted); display: flex; flex-direction: column; gap: 0.25rem; font-weight: 500; }
    .p-meta-info span { display: flex; align-items: center; gap: 0.5rem; }

    .p-btn-action {
        width: 50px; height: 50px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f8fafc;
        color: var(--accent-purple);
        border: 1px solid var(--card-border);
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .p-btn-action:hover {
        background: var(--accent-purple);
        color: white;
        transform: rotate(-10deg) scale(1.1);
        border-color: var(--accent-purple);
    }

    .empty-state { text-align: center; padding: 6rem 2rem; background: white; border-radius: 30px; border: 1px solid var(--card-border); }

    @media (max-width: 768px) {
        .dashboard-container { padding: 2rem 1rem; }
        .projects-grid { grid-template-columns: 1fr; }
    }
</style>
{% endblock %}

{% block body %}
<div class="dashboard-container">

    <!-- SUMMARY -->
    <div class="summary-grid">
        <div class="summary-card">
            <div class="sum-icon">📂</div>
            <div class="sum-info">
                <h4>Projets Actifs</h4>
                <span>{{ totalProjects }}</span>
            </div>
        </div>
        <div class="summary-card">
            <div class="sum-icon" style="background: #ecfdf5; color: #10b981;">✅</div>
            <div class="sum-info">
                <h4>Terminés</h4>
                <span>{{ completedProjects }}</span>
            </div>
        </div>
        <div class="summary-card">
            <div class="sum-icon" style="background: #f5f3ff; color: #7c3dac;">⚡</div>
            <div class="sum-info">
                <h4>Total Tâches</h4>
                <span>{{ totalTasks }}</span>
            </div>
        </div>
    </div>

    <div class="dashboard-header">
        <h2>Mes Missions</h2>
        <p style="color: var(--text-muted); margin-top: 0.5rem;">Vue d'ensemble de vos responsabilités opérationnelles.</p>
    </div>

    {% if projetsData is empty %}
        <div class="empty-state">
            <h3 style="color: var(--text-dark); font-size: 1.5rem; margin-bottom: 1rem;">Horizon dégagé</h3>
            <p style="color: var(--text-muted);">Vous n'avez pas encore d'assignation en cours. Profitez-en pour préparer la suite !</p>
        </div>
    {% else %}
        <div class="projects-grid">
            {% for data in projetsData %}
                {% set projet = data.entity %}
                <div class="premium-project-card">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.5rem;">
                        <span class="badge-modern status-{{ projet.statut|lower }}">
                            {{ projet.statut|replace({'_': ' '}) }}
                        </span>
                        <div style="font-weight: 700; color: #cbd5e1; font-size: 0.9rem;">
                            #{{ loop.index < 10 ? '0' ~ loop.index : loop.index }}
                        </div>
                    </div>

                    <h3 class="p-title">{{ projet.titre }}</h3>
                    <p class="p-desc">{{ projet.description ?: 'Opération stratégique en phase de déploiement.' }}</p>

                    <div class="p-progress-container">
                        <div class="p-progress-meta">
                            <span style="color: var(--text-muted); font-size: 0.85rem; font-weight: 600;">Progression</span>
                            <span class="p-progress-val">{{ data.progress }}%</span>
                        </div>
                        <div class="p-progress-bar-bg">
                            <div class="p-progress-bar-fill" style="width: {{ data.progress }}%;"></div>
                        </div>
                        <div style="margin-top: 0.75rem; display: flex; justify-content: space-between; font-size: 0.75rem; font-weight: 700; color: #94a3b8;">
                            <span>{{ data.completedTasks }} COMPLÉTÉES</span>
                            <span>{{ data.totalTasks }} TOTAL</span>
                        </div>
                    </div>

                    <div class="p-card-footer">
                        <div class="p-meta-info">
                            <span><i class="bi bi-calendar3"></i> Début: {{ projet.dateDebut|date('d/m/Y') }}</span>
                            <span><i class="bi bi-clock-history"></i> Fin: {{ projet.dateFin|date('d/m/Y') }}</span>
                        </div>
                        <a href="{{ path('app_tache_par_projet', {'projetId': projet.id}) }}" class="p-btn-action" title="Voir les tâches">
                            <i class="bi bi-arrow-right-short" style="font-size: 1.5rem;"></i>
                        </a>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}