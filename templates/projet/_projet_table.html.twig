    <table class="admin-table table-hover mb-0">
        <thead>
            <tr>
                <th style="width: 80px;"># ID</th>
                <th>Titre du projet</th>
                <th>Début</th>
                <th>Fin</th>
                <th>Statut</th>
                <th>Responsable</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for projet in projets %}
            {% set emp = projet.responsableEmploye %}
            <tr>
                <td class="text-muted fw-bold">#{{ projet.id }}</td>
                <td>
                    <div class="fw-bold text-dark fs-6">{{ projet.titre }}</div>
                </td>
                <td>
                    <div class="text-muted" style="font-size: 0.85rem;">
                        <i class="bi bi-calendar-event me-1 text-purple-mid"></i> {{ projet.dateDebut|date('d/m/Y') }}
                    </div>
                </td>
                <td>
                    <div class="text-muted" style="font-size: 0.85rem;">
                        <i class="bi bi-calendar-check me-1 text-purple-mid"></i> {{ projet.dateFin|date('d/m/Y') }}
                    </div>
                </td>
                <td>
                    {% if projet.statut == 'termine' %}
                        <span class="badge-soft badge-soft-success">✔ DONE</span>
                    {% elseif projet.statut == 'en_cours' %}
                        <span class="badge-soft badge-soft-warning">⌛ DOING</span>
                    {% elseif projet.statut == 'en_attente' %}
                        <span class="badge-soft badge-soft-warning" style="background: #fff4e5; color: #ffab00;">🕒 TO DO</span>
                    {% else %}
                        <span class="badge-soft" style="color:#ef4444; background:#fee2e2;">✖ CANCELLED</span>
                    {% endif %}
                </td>
                <td>
                    {% if emp and emp.user %}
                        <div class="table-avatar-group">
                            {% if emp.user.avatarPath %}
                                <img src="{{ asset(emp.user.avatarPath) }}" class="table-avatar" alt="">
                            {% else %}
                                <div class="table-avatar-initials" style="background: var(--purple-mid);">
                                    {{ emp.user.prenom|first|upper }}
                                </div>
                            {% endif %}
                            <div class="d-flex flex-column">
                                <span class="fw-bold text-dark" style="font-size: 0.9rem;">{{ emp.user.nom|first|upper }}</span>
                                <span class="text-muted" style="font-size: 0.8rem;">{{ emp.user.fullName }}</span>
                            </div>
                        </div>
                    {% else %}
                        <span class="text-muted fst-italic" style="font-size: 0.85rem;">Non assigné</span>
                    {% endif %}
                </td>
                <td class="text-end">
                    <div class="d-flex justify-content-end align-items-center gap-1">
                        <a href="{{ path('app_projet_taches_view', {'id': projet.id}) }}" class="btn-action-circle outline" title="Voir les tâches" style="color: var(--purple-mid); border-color: var(--purple-mid);">
                            <i class="bi bi-list-check"></i>
                        </a>
                        <a href="{{ path('app_projet_show', {'id': projet.id}) }}" class="btn-action-circle outline" title="Voir">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a href="{{ path('app_projet_edit', {'id': projet.id}) }}" class="btn-action-circle solid" title="Modifier">
                            <i class="bi bi-pencil-fill"></i>
                        </a>
                        <form method="post" action="{{ path('app_projet_delete', {'id': projet.id}) }}" style="display:inline-block;" onsubmit="return confirm('Supprimer ce projet ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ projet.id) }}">
                            <button class="btn-action-circle outline" style="color: #ef4444; border-color: #ef4444;" title="Supprimer">
                                <i class="bi bi-trash-fill"></i>
                            </button>
                        </form>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6" class="text-center py-5 text-muted"> 
                    <i class="bi bi-inbox fs-2 d-block mb-3 text-purple-light"></i> 
                    Aucun projet trouvé pour cette configuration.
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
