{% extends 'rh/admin_base.html.twig' %}
{% block page_title %}Gestion des Projets{% endblock %}
{% block page_subtitle %}Pilotez vos projets et suivez leur avancement en temps réel{% endblock %}
{% block admin_content %}

<div class="admin-card" style="padding:0;margin-bottom:1.5rem;margin-top:-1rem">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 p-4">
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <div class="admin-card-title mb-0">
                <div class="admin-card-title-icon"><i class="bi bi-diagram-3-fill"></i></div>
                Projets
            </div>
            <form id="ajaxSearchForm" method="get" action="{{ path('app_projet_index') }}" class="d-flex gap-2 flex-wrap">
                <div class="proj-search-wrap">
                    <i class="bi bi-search proj-search-icon"></i>
                    <input type="text" id="searchInput" name="q" value="{{ q|default('') }}" class="proj-search-input" placeholder="Rechercher un projet...">
                    <div id="searchSpinner" class="spinner-border spinner-border-sm" role="status" style="display:none;position:absolute;right:14px;top:50%;transform:translateY(-50%);color:#6b2d8b"><span class="visually-hidden">...</span></div>
                </div>
                <select id="statutSelect" name="statut" class="proj-filter-select">
                    <option value="">Tous les statuts</option>
                    <option value="en_attente" {% if statut|default('')=='en_attente' %}selected{% endif %}>🕒 À Faire</option>
                    <option value="en_cours"   {% if statut|default('')=='en_cours'   %}selected{% endif %}>⌛ En cours</option>
                    <option value="termine"    {% if statut|default('')=='termine'    %}selected{% endif %}>✔ Terminé</option>
                    <option value="annule"     {% if statut|default('')=='annule'     %}selected{% endif %}>✖ Annulé</option>
                </select>
            </form>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_projet_export_stats') }}" class="btn-light-purple d-inline-flex align-items-center gap-2" target="_blank"><i class="bi bi-file-earmark-bar-graph"></i> Rapport PDF</a>
            <a href="{{ path('app_projet_new') }}" class="btn-purple d-inline-flex align-items-center gap-2"><i class="bi bi-plus-lg"></i> Nouveau Projet</a>
        </div>
    </div>
</div>

<div class="d-flex justify-content-end mb-3 gap-2">
    <button class="proj-view-btn active" id="btnTable" onclick="setView('table')" title="Vue tableau"><i class="bi bi-table"></i></button>
    <button class="proj-view-btn" id="btnCards" onclick="setView('cards')" title="Vue cartes"><i class="bi bi-grid-3x3-gap-fill"></i></button>
</div>

<div id="viewTable">
    <div id="tableContainer" style="transition:opacity .2s">
        {% include 'projet/_projet_table.html.twig' %}
    </div>
</div>

<div id="viewCards" style="display:none">
    <div class="row g-4">
        {% for projet in projets %}
        {% set emp = projet.responsableEmploye %}
        <div class="col-md-6 col-xl-4">
            <div class="proj-card">
                <div class="d-flex justify-content-between align-items-center">
                    <div class="proj-card-icon"><i class="bi bi-diagram-3-fill"></i></div>
                    {% if projet.statut == 'termine' %}<span class="badge-soft badge-soft-success">✔ Terminé</span>
                    {% elseif projet.statut == 'en_cours' %}<span class="badge-soft badge-soft-warning">⌛ En cours</span>
                    {% elseif projet.statut == 'annule' %}<span class="badge-soft" style="color:#ef4444;background:#fee2e2">✖ Annulé</span>
                    {% else %}<span class="badge-soft badge-soft-warning" style="background:#dbeafe;color:#2563eb">🕒 À faire</span>{% endif %}
                </div>
                <h5 class="proj-card-title">{{ projet.titre }}</h5>
                {% if projet.description %}<p class="proj-card-desc">{{ projet.description|slice(0,90) }}{% if projet.description|length > 90 %}…{% endif %}</p>{% endif %}
                <div class="proj-card-dates">
                    <span><i class="bi bi-calendar-event"></i> {{ projet.dateDebut|date('d/m/Y') }}</span>
                    <span><i class="bi bi-calendar-check"></i> {{ projet.dateFin|date('d/m/Y') }}</span>
                </div>
                {% if emp and emp.user %}
                <div class="proj-card-resp">
                    {% if emp.user.avatarPath %}<img src="{{ asset(emp.user.avatarPath) }}" class="proj-card-avatar" alt="">
                    {% else %}<div class="proj-card-avatar-init">{{ emp.user.prenom|first|upper }}</div>{% endif %}
                    <span>{{ emp.user.fullName }}</span>
                </div>
                {% endif %}
                <div class="proj-card-actions">
                    <a href="{{ path('app_projet_show', {'id': projet.id}) }}" class="btn-action-circle outline" title="Voir"><i class="bi bi-eye"></i></a>
                    <a href="{{ path('app_projet_taches_view', {'id': projet.id}) }}" class="btn-action-circle outline" title="Tâches" style="color:var(--purple-mid);border-color:var(--purple-mid)"><i class="bi bi-list-check"></i></a>
                    <a href="{{ path('app_projet_edit', {'id': projet.id}) }}" class="btn-action-circle solid" title="Modifier"><i class="bi bi-pencil-fill"></i></a>
                    <form method="post" action="{{ path('app_projet_delete', {'id': projet.id}) }}" style="display:inline-block" onsubmit="return confirm('Supprimer ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete'~projet.id) }}">
                        <button class="btn-action-circle outline" style="color:#ef4444;border-color:#ef4444" title="Supprimer"><i class="bi bi-trash-fill"></i></button>
                    </form>
                </div>
            </div>
        </div>
        {% else %}
        <div class="col-12 text-center py-5 text-muted"><i class="bi bi-inbox fs-1 d-block mb-3"></i>Aucun projet trouvé.</div>
        {% endfor %}
    </div>
</div>

<style>
.proj-search-wrap{position:relative;display:flex;align-items:center}
.proj-search-icon{position:absolute;left:14px;color:#94a3b8;font-size:.9rem;pointer-events:none}
.proj-search-input{padding:9px 40px 9px 38px;border:1.5px solid #e2e8f0;border-radius:50px;font-size:.9rem;outline:none;background:#f8fafc;width:260px;transition:all .2s}
.proj-search-input:focus{border-color:#6b2d8b;box-shadow:0 0 0 3px rgba(107,45,139,.1);background:#fff}
.proj-filter-select{padding:9px 16px;border:1.5px solid #e2e8f0;border-radius:50px;font-size:.85rem;outline:none;background:#f8fafc;cursor:pointer}
.proj-filter-select:focus{border-color:#6b2d8b}
.proj-view-btn{width:36px;height:36px;border-radius:10px;border:1.5px solid #e2e8f0;background:#fff;color:#94a3b8;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s}
.proj-view-btn.active,.proj-view-btn:hover{background:#6b2d8b;border-color:#6b2d8b;color:#fff}
.proj-card{background:#fff;border-radius:20px;padding:22px;box-shadow:0 4px 20px rgba(0,0,0,.07);border:1px solid #f1f5f9;transition:transform .2s,box-shadow .2s;height:100%;display:flex;flex-direction:column;gap:10px}
.proj-card:hover{transform:translateY(-4px);box-shadow:0 12px 40px rgba(107,45,139,.15)}
.proj-card-icon{width:40px;height:40px;border-radius:12px;background:#6b2d8b;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1rem}
.proj-card-title{font-size:.95rem;font-weight:700;color:#1e293b;margin:0}
.proj-card-desc{font-size:.82rem;color:#64748b;margin:0;flex:1}
.proj-card-dates{display:flex;gap:14px;font-size:.78rem;color:#94a3b8}
.proj-card-dates span{display:flex;align-items:center;gap:4px}
.proj-card-resp{display:flex;align-items:center;gap:8px;font-size:.82rem;color:#475569;font-weight:500;padding-top:6px;border-top:1px solid #f1f5f9}
.proj-card-avatar{width:26px;height:26px;border-radius:50%;object-fit:cover}
.proj-card-avatar-init{width:26px;height:26px;border-radius:50%;background:#6b2d8b;color:#fff;display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:700}
.proj-card-actions{display:flex;gap:5px;flex-wrap:wrap;padding-top:6px;border-top:1px solid #f1f5f9;margin-top:auto}
</style>

{% endblock %}

{% block javascripts %}
<script>
function setView(v){
    document.getElementById('viewTable').style.display=v==='table'?'':'none';
    document.getElementById('viewCards').style.display=v==='cards'?'':'none';
    document.getElementById('btnTable').classList.toggle('active',v==='table');
    document.getElementById('btnCards').classList.toggle('active',v==='cards');
    localStorage.setItem('projView',v);
}
const sv=localStorage.getItem('projView'); if(sv)setView(sv);

document.addEventListener('DOMContentLoaded',function(){
    const form=document.getElementById('ajaxSearchForm');
    const inp=document.getElementById('searchInput');
    const sel=document.getElementById('statutSelect');
    const tbl=document.getElementById('tableContainer');
    const spin=document.getElementById('searchSpinner');
    let timer;
    function search(){
        const url=new URL(window.location.href);
        url.searchParams.set('q',inp.value);
        url.searchParams.set('statut',sel.value);
        window.history.replaceState({},'',url);
        spin.style.display='block'; tbl.style.opacity='.5';
        fetch(url.toString(),{headers:{'X-Requested-With':'XMLHttpRequest'}})
            .then(r=>r.text()).then(html=>{tbl.innerHTML=html;})
            .finally(()=>{spin.style.display='none';tbl.style.opacity='1';});
    }
    inp.addEventListener('input',()=>{clearTimeout(timer);timer=setTimeout(search,400);});
    sel.addEventListener('change',search);
    form.addEventListener('submit',e=>{e.preventDefault();search();});
});
</script>
{% endblock %}
