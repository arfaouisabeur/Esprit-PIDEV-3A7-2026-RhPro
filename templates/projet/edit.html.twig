{% extends 'rh/admin_base.html.twig' %}

{% block title %}Modifier le Projet{% endblock %}

{% block page_title %}Modifier le Projet{% endblock %}
{% block page_subtitle %}Modifiez les détails, les dates ou le responsable du projet #{{ projet.id }}{% endblock %}

{% block admin_content %}
<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="admin-card">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div class="d-flex align-items-center gap-3">
                    <a href="{{ path('app_projet_index') }}" class="btn-action-circle outline">
                        <i class="bi bi-arrow-left"></i>
                    </a>
                    <div class="admin-card-title mb-0">
                        <div class="admin-card-title-icon"><i class="bi bi-pencil-square"></i></div>
                        Édition du projet <span class="text-muted ms-2 fw-normal">#{{ projet.id }}</span>
                    </div>
                </div>
                
                {{ include('projet/_delete_form.html.twig') }}
            </div>

            <div class="p-2">
                {{ include('projet/_form.html.twig', {'button_label': 'Mettre à jour le projet'}) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}