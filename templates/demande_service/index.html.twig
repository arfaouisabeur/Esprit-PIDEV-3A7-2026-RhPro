<div id="statsSvcModal" class="stats-modal-overlay">
  <div class="stats-modal-box">
    <button class="stats-close-btn"
            onclick="document.getElementById('statsSvcModal').style.display='none'">
      <i class="fas fa-xmark"></i>
    </button>

    <div class="stats-title"><i class="fas fa-chart-pie"></i> Statistiques — Services</div>
    <p class="stats-sub">Répartition des demandes de service par statut</p>

    <div class="stats-grid">
      <div><canvas id="svcChart" width="280" height="280"></canvas></div>
      <div style="display:flex;flex-direction:column;gap:12px;">
        <div class="stat-item si-pend">
          <div class="stat-dot" style="background:#f59e0b;"></div>
          <div>
            <div class="stat-num" id="svc-pend">0</div>
            <div class="stat-lbl" style="color:#92400e;">En attente</div>
          </div>
        </div>
        <div class="stat-item si-ok">
          <div class="stat-dot" style="background:#10b981;"></div>
          <div>
            <div class="stat-num" id="svc-ok">0</div>
            <div class="stat-lbl" style="color:#065f46;">Acceptées</div>
          </div>
        </div>
        <div class="stat-item si-no">
          <div class="stat-dot" style="background:#f43f5e;"></div>
          <div>
            <div class="stat-num" id="svc-no">0</div>
            <div class="stat-lbl" style="color:#9f1239;">Refusées</div>
          </div>
        </div>
        <div class="stat-item si-total">
          <div class="stat-dot" style="background:var(--mv-600);"></div>
          <div>
            <div class="stat-num" id="svc-total">0</div>
            <div class="stat-lbl" style="color:var(--mv-800);">Total</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function(){
  var p = {{ demande_services|filter(d => d.statut == 'En attente')|length }};
  var a = {{ demande_services|filter(d => d.statut == 'Accepté' or d.statut == 'approuvé')|length }};
  var r = {{ demande_services|filter(d => d.statut == 'Refusé'  or d.statut == 'refusé')|length }};
  var t = p + a + r;

  document.getElementById('svc-pend').textContent  = p;
  document.getElementById('svc-ok').textContent    = a;
  document.getElementById('svc-no').textContent    = r;
  document.getElementById('svc-total').textContent = t;

  document.getElementById('statsSvcModal').addEventListener('click', function(e){
    if(e.target===this) this.style.display='none';
  });

  new Chart(document.getElementById('svcChart').getContext('2d'), {
    type: 'doughnut',
    data: {
      labels: ['En attente','Acceptées','Refusées'],
      datasets:[{
        data:[p,a,r],
        backgroundColor:['#f59e0b','#10b981','#f43f5e'],
        borderColor:['#fff','#fff','#fff'],
        borderWidth:3,
        hoverOffset:14
      }]
    },
    options:{
      cutout:'65%',
      animation:{animateRotate:true,duration:1000},
      plugins:{
        legend:{display:false},
        tooltip:{callbacks:{label:function(c){var pct=t>0?Math.round(c.parsed/t*100):0;return ' '+c.raw+' ('+pct+'%)';}}}
      }
    }
  });
})();
</script>
