{% extends 'base.html.twig' %}
{% block title %}Statistiques RH — RH Pro{% endblock %}

{% block styles %}
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
:root {
  --green:#10b981;--green-dark:#059669;--green-light:#d1fae5;
  --blue:#3b82f6;--blue-light:#dbeafe;
  --amber:#f59e0b;--amber-light:#fef3c7;
  --red:#ef4444;--red-light:#fee2e2;
  --violet:#8b5cf6;--violet-light:#ede9fe;
  --surface:#f0fdf9;--border:#e5e7eb;--text:#111827;--muted:#6b7280;
  --sidebar-w:240px;
}
*,*::before,*::after{box-sizing:border-box;}
body{margin:0;padding:0;font-family:'Inter',sans-serif;background:var(--surface);color:var(--text);}

/* ── Layout ─────────────────────────────────────── */
.rh-wrap{display:flex;min-height:100vh;}
.rh-sidebar{width:var(--sidebar-w);background:#fff;border-right:1px solid var(--border);position:fixed;top:0;left:0;height:100vh;overflow-y:auto;display:flex;flex-direction:column;z-index:100;}
.rh-main{margin-left:var(--sidebar-w);flex:1;padding:0 0 60px;}

/* ── Sidebar ─────────────────────────────────────── */
.sb-brand{padding:22px 20px 16px;border-bottom:1px solid var(--border);}
.sb-logo{display:flex;align-items:center;gap:10px;font-size:16px;font-weight:800;color:var(--green-dark);text-decoration:none;}
.sb-logo-icon{width:36px;height:36px;background:linear-gradient(135deg,#10b981,#059669);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;color:#fff;}
.sb-nav{padding:14px 12px;flex:1;}
.sb-section-label{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;padding:12px 8px 6px;margin:0;}
.sb-link{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;margin-bottom:2px;font-size:13px;font-weight:500;color:#374151;text-decoration:none;transition:background .15s,color .15s;}
.sb-link:hover{background:var(--green-light);color:var(--green-dark);text-decoration:none;}
.sb-link.active{background:var(--green-light);color:var(--green-dark);font-weight:700;}
.sb-link svg{flex-shrink:0;opacity:.7;}
.sb-link.active svg,.sb-link:hover svg{opacity:1;}
.sb-count{margin-left:auto;font-size:10px;font-weight:700;padding:1px 7px;border-radius:100px;}
.sb-bottom{padding:14px 12px;border-top:1px solid var(--border);}
.sb-user{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;background:#f9fafb;}
.sb-avatar{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,#10b981,#059669);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#fff;flex-shrink:0;}
.sb-user-name{font-size:13px;font-weight:600;color:var(--text);}
.sb-user-role{font-size:11px;color:var(--muted);}

/* ── Top bar ─────────────────────────────────────── */
.rh-topbar{background:#fff;border-bottom:1px solid var(--border);padding:16px 32px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:90;box-shadow:0 1px 4px rgba(0,0,0,.04);}
.rh-topbar-title{font-size:20px;font-weight:700;color:var(--text);margin:0;}
.rh-topbar-sub{font-size:13px;color:var(--muted);margin:2px 0 0;}
.topbar-right{display:flex;align-items:center;gap:10px;}
.btn-refresh{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:9px;font-size:12px;font-weight:600;background:var(--green-light);color:var(--green-dark);border:none;cursor:pointer;font-family:'Inter',sans-serif;transition:background .2s;}
.btn-refresh:hover{background:#a7f3d0;}
.btn-refresh.loading svg{animation:spin .8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
.live-dot{width:8px;height:8px;border-radius:50%;background:var(--green);animation:pulse 2s ease-in-out infinite;display:inline-block;margin-left:4px;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:.5;transform:scale(1.4);}}

/* ── Page body ───────────────────────────────────── */
.stats-body{padding:28px 32px 0;}

/* ── KPI Cards ───────────────────────────────────── */
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px;}
@media(max-width:1100px){.kpi-grid{grid-template-columns:repeat(2,1fr);}}
@media(max-width:600px){.kpi-grid{grid-template-columns:1fr;}}
.kpi-card{background:#fff;border-radius:16px;border:1px solid var(--border);padding:20px 22px;box-shadow:0 2px 8px rgba(0,0,0,.04);position:relative;overflow:hidden;transition:transform .2s,box-shadow .2s;}
.kpi-card:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,0,0,.08);}
.kpi-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;}
.kpi-card.blue::before{background:linear-gradient(90deg,#3b82f6,#2563eb);}
.kpi-card.green::before{background:linear-gradient(90deg,#10b981,#059669);}
.kpi-card.amber::before{background:linear-gradient(90deg,#f59e0b,#d97706);}
.kpi-card.violet::before{background:linear-gradient(90deg,#8b5cf6,#7c3aed);}
.kpi-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px;}
.kpi-icon{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;}
.kpi-icon.blue{background:var(--blue-light);}.kpi-icon.green{background:var(--green-light);}.kpi-icon.amber{background:var(--amber-light);}.kpi-icon.violet{background:var(--violet-light);}
.kpi-badge{font-size:10px;font-weight:700;padding:3px 8px;border-radius:100px;text-transform:uppercase;letter-spacing:.05em;}
.badge-up{background:#d1fae5;color:#065f46;}.badge-down{background:#fee2e2;color:#991b1b;}.badge-neutral{background:#f3f4f6;color:#6b7280;}
.kpi-num{font-size:34px;font-weight:800;color:var(--text);line-height:1;margin-bottom:4px;letter-spacing:-1px;}
.kpi-label{font-size:12px;color:var(--muted);font-weight:500;}
.kpi-sub{font-size:11px;color:var(--muted);margin-top:8px;}
.kpi-progress{height:5px;background:#f3f4f6;border-radius:100px;margin-top:12px;overflow:hidden;}
.kpi-progress-bar{height:5px;border-radius:100px;transition:width .8s ease;}

/* ── Sections ────────────────────────────────────── */
.section-title{font-size:18px;font-weight:700;color:var(--text);margin:0 0 16px;display:flex;align-items:center;gap:8px;}
.section-sub{font-size:13px;color:var(--muted);margin:-10px 0 18px;}

/* ── Charts ──────────────────────────────────────── */
.charts-row{display:grid;grid-template-columns:1.5fr 1fr;gap:20px;margin-bottom:28px;}
@media(max-width:900px){.charts-row{grid-template-columns:1fr;}}
.chart-card{background:#fff;border-radius:16px;border:1px solid var(--border);box-shadow:0 2px 8px rgba(0,0,0,.04);padding:24px;}
.chart-card-title{font-size:15px;font-weight:700;color:var(--text);margin:0 0 4px;display:flex;align-items:center;gap:8px;}
.chart-card-sub{font-size:12px;color:var(--muted);margin:0 0 20px;}

/* Donut */
.donut-wrap{position:relative;max-width:200px;margin:0 auto;}
.donut-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;pointer-events:none;}
.donut-center-num{font-size:28px;font-weight:800;color:var(--text);line-height:1;}
.donut-center-lbl{font-size:11px;color:var(--muted);}
.donut-legend{display:flex;flex-direction:column;gap:10px;margin-top:16px;}
.leg-row{display:flex;align-items:center;justify-content:space-between;font-size:12px;color:#374151;}
.leg-dot{width:10px;height:10px;border-radius:50%;margin-right:7px;flex-shrink:0;}
.leg-lbl{display:flex;align-items:center;flex:1;}
.leg-val{font-weight:700;color:var(--text);}

/* ── Top événements ──────────────────────────────── */
.top-ev-card{background:#fff;border-radius:16px;border:1px solid var(--border);box-shadow:0 2px 8px rgba(0,0,0,.04);overflow:hidden;margin-bottom:28px;}
.top-ev-header{display:flex;align-items:center;justify-content:space-between;padding:18px 24px;border-bottom:1px solid var(--border);}
.top-ev-title{font-size:15px;font-weight:700;color:var(--text);margin:0;display:flex;align-items:center;gap:8px;}
.see-all-link{font-size:12px;font-weight:600;color:var(--green-dark);text-decoration:none;display:flex;align-items:center;gap:4px;}
.see-all-link:hover{text-decoration:underline;}
.top-ev-item{display:flex;align-items:center;gap:16px;padding:14px 24px;border-bottom:1px solid #f3f4f6;transition:background .15s;}
.top-ev-item:last-child{border-bottom:none;}
.top-ev-item:hover{background:#f9fefb;}
.top-ev-rank{width:28px;height:28px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;flex-shrink:0;}
.rank-1{background:#fef3c7;color:#92400e;}
.rank-2{background:#f3f4f6;color:#374151;}
.rank-3{background:#fde8d0;color:#c2410c;}
.rank-other{background:var(--green-light);color:var(--green-dark);}
.top-ev-info{flex:1;min-width:0;}
.top-ev-name{font-size:13px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:6px;}
.top-ev-meta{display:flex;align-items:center;gap:12px;font-size:11px;color:var(--muted);}
.bar-wrap{flex:1;height:8px;background:#f3f4f6;border-radius:100px;overflow:hidden;}
.bar-fill{height:8px;border-radius:100px;background:linear-gradient(90deg,#10b981,#059669);transition:width .8s ease;}
.top-ev-count{font-size:16px;font-weight:800;color:var(--green-dark);flex-shrink:0;min-width:24px;text-align:right;}

/* ── Résumé table (candidats/employés actifs) ────── */
.summary-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:28px;}
@media(max-width:900px){.summary-grid{grid-template-columns:1fr;}}
.summary-card{background:#fff;border-radius:16px;border:1px solid var(--border);box-shadow:0 2px 8px rgba(0,0,0,.04);overflow:hidden;}
.summary-header{display:flex;align-items:center;justify-content:space-between;padding:16px 22px;border-bottom:1px solid var(--border);}
.summary-title{font-size:14px;font-weight:700;color:var(--text);margin:0;display:flex;align-items:center;gap:7px;}
table.sumtable{width:100%;border-collapse:collapse;}
.sumtable th{font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;padding:10px 22px;text-align:left;background:#f9fafb;border-bottom:1px solid var(--border);}
.sumtable td{padding:12px 22px;font-size:13px;color:var(--text);border-bottom:1px solid #f3f4f6;vertical-align:middle;}
.sumtable tr:last-child td{border-bottom:none;}
.sumtable tbody tr:hover td{background:#f9fefb;}
.u-av{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;flex-shrink:0;}
.u-row{display:flex;align-items:center;gap:10px;}
.u-nm{font-weight:600;font-size:13px;}.u-em{font-size:11px;color:var(--muted);}
.bs{display:inline-flex;gap:4px;align-items:center;padding:3px 9px;border-radius:100px;font-size:11px;font-weight:600;}
.bs-a{background:#d1fae5;color:#065f46;}.bs-i{background:#fee2e2;color:#991b1b;}
.no-data{text-align:center;padding:32px;color:var(--muted);font-size:13px;}
{% endblock %}

{% block body %}
<div class="rh-wrap">

  {# ── Sidebar ──────────────────────────────────────────────────── #}
  <aside class="rh-sidebar">
    <div class="sb-brand">
      <a href="{{ path('app_rh_dashboard') }}" class="sb-logo">
        <div class="sb-logo-icon">🏢</div>
        <span>RH Pro</span>
      </a>
    </div>
    <nav class="sb-nav">
      <p class="sb-section-label">Tableau de bord</p>
      <a href="{{ path('app_rh_dashboard') }}" class="sb-link">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        Dashboard
      </a>
      <a href="{{ path('app_rh_stats') }}" class="sb-link active">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        Statistiques
      </a>

      <p class="sb-section-label">Gestion RH</p>
      <a href="{{ path('app_rh_candidats') }}" class="sb-link">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
        Candidats
        {% if candidats|length > 0 %}
          <span class="sb-count" style="background:var(--blue-light);color:#1d4ed8;">{{ candidats|length }}</span>
        {% endif %}
      </a>
      <a href="{{ path('app_rh_employes') }}" class="sb-link">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
        Employés
        {% if employes|length > 0 %}
          <span class="sb-count" style="background:var(--green-light);color:var(--green-dark);">{{ employes|length }}</span>
        {% endif %}
      </a>

      <p class="sb-section-label">Événements</p>
      <a href="{{ path('app_evenement_index') }}" class="sb-link">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Événements
        {% if evenements|length > 0 %}
          <span class="sb-count" style="background:var(--amber-light);color:#92400e;">{{ evenements|length }}</span>
        {% endif %}
      </a>
      <a href="{{ path('app_event_participation_index') }}" class="sb-link">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Participations
        {% if pEnAttente > 0 %}
          <span class="sb-count" style="background:var(--red-light);color:#991b1b;">{{ pEnAttente }}</span>
        {% endif %}
      </a>
    </nav>
    <div class="sb-bottom">
      <div class="sb-user">
        <div class="sb-avatar">{{ app.user ? app.user.prenom|first|upper : 'R' }}</div>
        <div>
          <div class="sb-user-name">{{ app.user ? app.user.prenom ~ ' ' ~ app.user.nom : 'RH' }}</div>
          <div class="sb-user-role">Responsable RH</div>
        </div>
      </div>
    </div>
  </aside>

  {# ── Main ─────────────────────────────────────────────────────── #}
  <main class="rh-main">

    <div class="rh-topbar">
      <div>
        <h1 class="rh-topbar-title">Statistiques RH</h1>
        <p class="rh-topbar-sub">
          Analyse en temps réel — mise à jour automatique
          <span class="live-dot"></span>
        </p>
      </div>
      <div class="topbar-right">
        <button class="btn-refresh" id="btn-refresh" onclick="refreshAll()">
          <svg id="ico-refresh" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <polyline points="23 4 23 10 17 10"/>
            <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
          </svg>
          Actualiser
        </button>
        <a href="{{ path('app_evenement_new') }}"
           style="display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:9px;font-size:12px;font-weight:600;background:var(--green);color:#fff;text-decoration:none;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Nouvel événement
        </a>
      </div>
    </div>

    <div class="stats-body">

      {# ── KPI Cards ──────────────────────────────────────────────── #}
      <div class="kpi-grid">

        <div class="kpi-card blue">
          <div class="kpi-top">
            <div class="kpi-icon blue">🎓</div>
            <span class="kpi-badge {{ candidatsActifs == candidats|length ? 'badge-up' : 'badge-neutral' }}" id="bdg-cand">
              {{ candidatsActifs }}/{{ candidats|length }} actifs
            </span>
          </div>
          <div class="kpi-num" id="kpi-cand">{{ candidats|length }}</div>
          <div class="kpi-label">Total Candidats</div>
          <div class="kpi-sub" id="sub-cand">{{ candidats|length - candidatsActifs }} inactif(s)</div>
          <div class="kpi-progress">
            <div class="kpi-progress-bar" style="width:{{ candidats|length > 0 ? (candidatsActifs / candidats|length * 100)|round : 0 }}%;background:#3b82f6;"></div>
          </div>
        </div>

        <div class="kpi-card green">
          <div class="kpi-top">
            <div class="kpi-icon green">👔</div>
            <span class="kpi-badge {{ employesActifs == employes|length ? 'badge-up' : 'badge-neutral' }}" id="bdg-emp">
              {{ employesActifs }}/{{ employes|length }} actifs
            </span>
          </div>
          <div class="kpi-num" id="kpi-emp">{{ employes|length }}</div>
          <div class="kpi-label">Total Employés</div>
          <div class="kpi-sub" id="sub-emp">{{ employes|length - employesActifs }} inactif(s)</div>
          <div class="kpi-progress">
            <div class="kpi-progress-bar" style="width:{{ employes|length > 0 ? (employesActifs / employes|length * 100)|round : 0 }}%;background:#10b981;"></div>
          </div>
        </div>

        <div class="kpi-card amber">
          <div class="kpi-top">
            <div class="kpi-icon amber">📅</div>
            <span class="kpi-badge {{ evEnCours > 0 ? 'badge-up' : 'badge-neutral' }}" id="bdg-ev">
              {{ evEnCours }} en cours
            </span>
          </div>
          <div class="kpi-num" id="kpi-ev">{{ evenements|length }}</div>
          <div class="kpi-label">Total Événements</div>
          <div class="kpi-sub" id="sub-ev">{{ evAVenir }} à venir · {{ evTermines }} terminé(s)</div>
          <div class="kpi-progress">
            <div class="kpi-progress-bar" style="width:{{ evenements|length > 0 ? (evEnCours / evenements|length * 100)|round : 0 }}%;background:#f59e0b;"></div>
          </div>
        </div>

        <div class="kpi-card violet">
          <div class="kpi-top">
            <div class="kpi-icon violet">🤝</div>
            <span class="kpi-badge {{ pEnAttente > 0 ? 'badge-down' : 'badge-up' }}" id="bdg-parts">
              {{ pEnAttente }} en attente
            </span>
          </div>
          <div class="kpi-num" id="kpi-parts">{{ participations|length }}</div>
          <div class="kpi-label">Participations totales</div>
          <div class="kpi-sub" id="sub-parts">{{ pAccepte }} acceptée(s) · {{ pRefuse }} refusée(s)</div>
          <div class="kpi-progress">
            <div class="kpi-progress-bar" style="width:{{ participations|length > 0 ? (pAccepte / participations|length * 100)|round : 0 }}%;background:#8b5cf6;"></div>
          </div>
        </div>

      </div>

      {# ── Graphiques ─────────────────────────────────────────────── #}
      <div class="charts-row">

        {# Bar chart — Événements #}
        <div class="chart-card">
          <h3 class="chart-card-title">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            Répartition des Événements
          </h3>
          <p class="chart-card-sub">À venir · En cours · Terminés</p>
          <canvas id="chartEv" height="220"></canvas>
        </div>

        {# Donut — Participations #}
        <div class="chart-card">
          <h3 class="chart-card-title">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Statuts des Participations
          </h3>
          <p class="chart-card-sub">Répartition par statut</p>
          <div class="donut-wrap">
            <canvas id="chartParts" height="200"></canvas>
            <div class="donut-center">
              <div class="donut-center-num" id="donut-tot">{{ participations|length }}</div>
              <div class="donut-center-lbl">total</div>
            </div>
          </div>
          <div class="donut-legend">
            <div class="leg-row">
              <span class="leg-lbl"><span class="leg-dot" style="background:#f59e0b"></span>En attente</span>
              <span class="leg-val" id="leg-att">{{ pEnAttente }}</span>
            </div>
            <div class="leg-row">
              <span class="leg-lbl"><span class="leg-dot" style="background:#10b981"></span>Acceptées</span>
              <span class="leg-val" id="leg-acc">{{ pAccepte }}</span>
            </div>
            <div class="leg-row">
              <span class="leg-lbl"><span class="leg-dot" style="background:#ef4444"></span>Refusées</span>
              <span class="leg-val" id="leg-ref">{{ pRefuse }}</span>
            </div>
          </div>
        </div>

      </div>

      {# ── Top 6 Événements ───────────────────────────────────────── #}
      <div class="top-ev-card">
        <div class="top-ev-header">
          <h3 class="top-ev-title">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            Classement des événements par participation
          </h3>
          <a href="{{ path('app_evenement_index') }}" class="see-all-link">
            Voir tous
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        </div>

        {% if topEvenements|length > 0 %}
          {% set maxCount = topEvenements|first %}
          {% set maxVal = maxCount['count'] > 0 ? maxCount['count'] : 1 %}
          {% for item in topEvenements %}
          {% set ev = item.ev %}
          {% set cnt = item.count %}
          {% set rankClass = loop.index == 1 ? 'rank-1' : (loop.index == 2 ? 'rank-2' : (loop.index == 3 ? 'rank-3' : 'rank-other')) %}
          <div class="top-ev-item">
            <div class="top-ev-rank {{ rankClass }}">{{ loop.index }}</div>
            <div class="top-ev-info">
              <div class="top-ev-name">{{ ev.titre }}</div>
              <div style="display:flex;align-items:center;gap:12px;margin-top:6px;">
                <div class="bar-wrap">
                  <div class="bar-fill" style="width:{{ (cnt / maxVal * 100)|round }}%"></div>
                </div>
                <div class="top-ev-meta">
                  <span>📍 {{ ev.lieu }}</span>
                  <span>{{ ev.dateDebut }} → {{ ev.dateFin }}</span>
                  {% set today2 = today %}
                  {% if ev.dateDebut > today2 %}
                    <span style="background:var(--blue-light);color:#1d4ed8;padding:1px 7px;border-radius:100px;font-size:10px;font-weight:700;">À venir</span>
                  {% elseif ev.dateDebut <= today2 and ev.dateFin >= today2 %}
                    <span style="background:var(--green-light);color:var(--green-dark);padding:1px 7px;border-radius:100px;font-size:10px;font-weight:700;">En cours</span>
                  {% else %}
                    <span style="background:#f3f4f6;color:#6b7280;padding:1px 7px;border-radius:100px;font-size:10px;font-weight:700;">Terminé</span>
                  {% endif %}
                </div>
              </div>
            </div>
            <div class="top-ev-count">{{ cnt }}</div>
          </div>
          {% endfor %}
        {% else %}
          <div class="no-data">Aucun événement créé — <a href="{{ path('app_evenement_new') }}" style="color:var(--green-dark);font-weight:600;">Créer le premier</a></div>
        {% endif %}
      </div>

      {# ── Candidats & Employés actifs ────────────────────────────── #}
      <div class="summary-grid">

        <div class="summary-card">
          <div class="summary-header">
            <h3 class="summary-title">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
              Candidats ({{ candidats|length }})
            </h3>
            <a href="{{ path('app_rh_candidats') }}" class="see-all-link">Voir tout <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg></a>
          </div>
          <table class="sumtable">
            <thead><tr><th>Candidat</th><th>Niveau</th><th>Statut</th></tr></thead>
            <tbody>
              {% for u in candidats|slice(0,5) %}
              <tr>
                <td>
                  <div class="u-row">
                    <div class="u-av" style="background:linear-gradient(135deg,#3b82f6,#2563eb)">{{ u.prenom|first|upper }}</div>
                    <div><div class="u-nm">{{ u.prenom }} {{ u.nom }}</div><div class="u-em">{{ u.email }}</div></div>
                  </div>
                </td>
                <td style="font-size:12px;color:var(--muted);">{{ u.candidat ? u.candidat.niveauEtude|default('—') : '—' }}</td>
                <td><span class="bs {{ u.statut == 'actif' ? 'bs-a' : 'bs-i' }}">● {{ u.statut == 'actif' ? 'Actif' : 'Inactif' }}</span></td>
              </tr>
              {% else %}
              <tr><td colspan="3" class="no-data">Aucun candidat</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>

        <div class="summary-card">
          <div class="summary-header">
            <h3 class="summary-title">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
              Employés ({{ employes|length }})
            </h3>
            <a href="{{ path('app_rh_employes') }}" class="see-all-link">Voir tout <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg></a>
          </div>
          <table class="sumtable">
            <thead><tr><th>Employé</th><th>Poste</th><th>Statut</th></tr></thead>
            <tbody>
              {% for u in employes|slice(0,5) %}
              <tr>
                <td>
                  <div class="u-row">
                    <div class="u-av">{{ u.prenom|first|upper }}</div>
                    <div><div class="u-nm">{{ u.prenom }} {{ u.nom }}</div><div class="u-em">{{ u.employe ? u.employe.matricule|default('—') : '—' }}</div></div>
                  </div>
                </td>
                <td style="font-size:12px;color:var(--muted);">{{ u.employe ? u.employe.position|default('—') : '—' }}</td>
                <td><span class="bs {{ u.statut == 'actif' ? 'bs-a' : 'bs-i' }}">● {{ u.statut == 'actif' ? 'Actif' : 'Inactif' }}</span></td>
              </tr>
              {% else %}
              <tr><td colspan="3" class="no-data">Aucun employé</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>

      </div>

    </div>{# /stats-body #}
  </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script>
Chart.defaults.font.family = "'Inter', sans-serif";
Chart.defaults.color = '#6b7280';

// ── Données initiales ────────────────────────────────────────────
const D = {
  evAVenir  : {{ evAVenir }},
  evEnCours : {{ evEnCours }},
  evTermines: {{ evTermines }},
  pEnAttente: {{ pEnAttente }},
  pAccepte  : {{ pAccepte }},
  pRefuse   : {{ pRefuse }},
  total     : {{ participations|length }},
};

// ── Bar chart — Événements ───────────────────────────────────────
const ctxEv = document.getElementById('chartEv').getContext('2d');
let chartEv = new Chart(ctxEv, {
  type: 'bar',
  data: {
    labels: ['À venir', 'En cours', 'Terminés'],
    datasets: [
      {
        label: 'Nombre',
        data: [D.evAVenir, D.evEnCours, D.evTermines],
        backgroundColor: ['rgba(59,130,246,.18)', 'rgba(16,185,129,.18)', 'rgba(156,163,175,.18)'],
        borderColor    : ['#3b82f6', '#10b981', '#9ca3af'],
        borderWidth: 2.5,
        borderRadius: 10,
        borderSkipped: false,
      }
    ]
  },
  options: {
    responsive: true,
    maintainAspectRatio: true,
    plugins: {
      legend: { display: false },
      tooltip: { callbacks: { label: c => ' ' + c.parsed.y + ' événement(s)' } }
    },
    scales: {
      y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: '#f3f4f6' } },
      x: { grid: { display: false }, ticks: { font: { weight: '600' } } }
    }
  }
});

// ── Donut — Participations ───────────────────────────────────────
const ctxP = document.getElementById('chartParts').getContext('2d');
let chartP = new Chart(ctxP, {
  type: 'doughnut',
  data: {
    labels: ['En attente', 'Acceptées', 'Refusées'],
    datasets: [{
      data: [D.pEnAttente, D.pAccepte, D.pRefuse],
      backgroundColor: ['#fef3c7', '#d1fae5', '#fee2e2'],
      borderColor    : ['#f59e0b', '#10b981', '#ef4444'],
      borderWidth: 2.5,
      hoverOffset: 10,
    }]
  },
  options: {
    responsive: true,
    maintainAspectRatio: true,
    cutout: '72%',
    plugins: {
      legend: { display: false },
      tooltip: { callbacks: { label: c => ' ' + c.parsed + ' participation(s)' } }
    }
  }
});

// ── Compteur animé ───────────────────────────────────────────────
function animCount(el, to, dur) {
  if (!el) return;
  const from = parseInt(el.textContent) || 0;
  if (from === to) return;
  const t0 = performance.now(), d = dur || 700;
  const frame = (now) => {
    const p = Math.min((now - t0) / d, 1);
    el.textContent = Math.round(from + (to - from) * (1 - Math.pow(1 - p, 3)));
    if (p < 1) requestAnimationFrame(frame);
  };
  requestAnimationFrame(frame);
}

// ── Rafraîchissement AJAX ────────────────────────────────────────
const AJAX_URL = '{{ path('app_rh_statistiques') }}';

function refreshAll() {
  const btn = document.getElementById('btn-refresh');
  const ico = document.getElementById('ico-refresh');
  if (btn) { btn.disabled = true; btn.classList.add('loading'); }

  fetch(AJAX_URL)
    .then(r => { if (!r.ok) throw new Error(r.status); return r.json(); })
    .then(d => {
      // Compteurs
      animCount(document.getElementById('kpi-cand'),  d.totalCandidats);
      animCount(document.getElementById('kpi-emp'),   d.totalEmployes);
      animCount(document.getElementById('kpi-ev'),    d.totalEvenements);
      animCount(document.getElementById('kpi-parts'), d.totalParticipations);
      animCount(document.getElementById('donut-tot'), d.totalParticipations);

      // Légendes donut
      const sa = el => document.getElementById(el);
      if (sa('leg-att')) sa('leg-att').textContent = d.pEnAttente;
      if (sa('leg-acc')) sa('leg-acc').textContent = d.pAccepte;
      if (sa('leg-ref')) sa('leg-ref').textContent = d.pRefuse;

      // Sous-titres KPI
      if (sa('sub-cand'))  sa('sub-cand').textContent  = (d.totalCandidats - d.candidatsActifs) + ' inactif(s)';
      if (sa('sub-emp'))   sa('sub-emp').textContent   = (d.totalEmployes  - d.employesActifs)  + ' inactif(s)';
      if (sa('sub-ev'))    sa('sub-ev').textContent    = d.evAVenir + ' à venir · ' + d.evTermines + ' terminé(s)';
      if (sa('sub-parts')) sa('sub-parts').textContent = d.pAccepte + ' acceptée(s) · ' + d.pRefuse + ' refusée(s)';

      // Graphiques
      chartEv.data.datasets[0].data = [d.evAVenir, d.evEnCours, d.evTermines];
      chartEv.update('active');

      chartP.data.datasets[0].data = [d.pEnAttente, d.pAccepte, d.pRefuse];
      chartP.update('active');
    })
    .catch(e => console.warn('Stats refresh error:', e))
    .finally(() => {
      if (btn) { btn.disabled = false; btn.classList.remove('loading'); }
    });
}

// Auto-refresh toutes les 60 secondes
refreshAll();
setInterval(refreshAll, 60000);
</script>
{% endblock %}
