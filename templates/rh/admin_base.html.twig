{% extends 'base.html.twig' %}

{% block title %}Admin - RH Pro{% endblock %}

{% block navbar %}
    {% include 'partials/header.html.twig' %}
{% endblock %}

{% block footer %}
    <!-- No public footer in admin area -->
{% endblock %}

{% block stylesheets %}

<style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:wght@700;800&display=swap');

    :root {
        --purple-dark: #662283;
        --purple-mid: #7e2b9c;
        --purple-light: #f3e5f5;
        --bg-light: #f8fafc;
        --card-radius: 24px;
    }
    
    body {
        background-color: var(--bg-light);
        font-family: 'Inter', sans-serif;
    }
 .admin-wrapper {
    background-color: var(--bg-light);
    min-height: 100vh;
    display: block; /* 🔥 THIS FIXES EVERYTHING */
    overflow-x: hidden;
}
   
    
    .admin-content {
        flex: 1;
        margin-left: 0px;
        display: flex;
        flex-direction: column;
        min-width: 0;
    }
    
    /* Top Banner */
    .admin-top-banner {
        background: var(--purple-dark) !important;
        color: white;
        padding: 2.5rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0;
    }
    .admin-top-banner h2 {
        font-weight: 700;
        margin-bottom: 0.2rem;
        font-size: 1.6rem;
    }
    .admin-top-banner p {
        color: rgba(255,255,255,0.7);
        font-size: 0.95rem;
        margin-bottom: 0;
    }
    .admin-top-banner .header-icon {
        width: 48px;
        height: 48px;
        background: rgba(255,255,255,0.15);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-right: 1rem;
    }
    
    /* Main Content Container */
    .admin-main-px {
        padding: 1.5rem 1rem;
    }
    
    /* Cards */
    .admin-card {
        background: #ffffff;
        border-radius: var(--card-radius);
        padding: 2rem;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        margin-bottom: 2rem;
    }
    .admin-card-title {
        display: flex;
        align-items: center;
        font-size: 1.25rem;
        font-weight: 700;
        color: #1a1a1a;
        margin-bottom: 1.5rem;
    }
    .admin-card-title-icon {
        width: 36px;
        height: 36px;
        background: var(--purple-dark);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-right: 12px;
        font-size: 1.1rem;
    }

    /* Buttons */
    .btn-purple {
        background-color: var(--purple-dark);
        color: white;
        border-radius: 50px;
        font-weight: 600;
        padding: 0.5rem 1.25rem;
        transition: all 0.2s ease;
        border: none;
    }
    .btn-purple:hover {
        background-color: var(--purple-mid);
        color: white;
    }
    .btn-light-purple {
        background-color: #f3e5f5;
        color: var(--purple-dark);
        border-radius: 50px;
        font-weight: 600;
        padding: 0.5rem 1.25rem;
        border: none;
        transition: all 0.2s ease;
    }
    .btn-light-purple:hover {
        background-color: #e1bee7;
        color: var(--purple-dark);
    }
    
    /* Tables */
    .admin-table-container {
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #eee;
    }
    .admin-table {
        margin: 0;
        width: 100%;
        border-collapse: collapse;
    }
    .admin-table thead {
        background-color: var(--purple-dark) !important;
        color: white !important;
    }
    .admin-table thead th {
        color: white !important;
        background-color: var(--purple-dark) !important;
        border: none;
    }
    .admin-table th {
        font-weight: 600;
        font-size: 0.8rem;
        text-transform: uppercase;
        padding: 1rem 1.25rem;
        border: none;
        letter-spacing: 0.05em;
    }
    .admin-table td {
        padding: 1rem 1.25rem;
        vertical-align: middle;
        font-size: 0.95rem;
        color: #334;
        border-bottom: 1px solid #f0f0f0;
        background-color: #ffffff;
    }
    .admin-table tbody tr:hover td {
        background-color: #fafafa;
    }
    
    /* Badges in table */
    .badge-soft {
        padding: 6px 12px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.75rem;
    }
    .badge-soft-purple {
        background-color: #f3e5f5;
        color: var(--purple-dark);
    }
    .badge-soft-warning {
        background-color: #fff8e1;
        color: #f57c00;
    }
    .badge-soft-success {
        background-color: #e8f5e9;
        color: #2e7d32;
    }
    
    /* Mini Action Buttons */
    .btn-action-circle {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
        margin-right: 4px;
        transition: all 0.2s;
    }
    .btn-action-circle.outline {
        border: 2px solid var(--purple-dark);
        color: var(--purple-dark);
        background: transparent;
    }
    .btn-action-circle.outline:hover {
        background: var(--purple-dark);
        color: white;
    }
    .btn-action-circle.solid {
        background: var(--purple-dark);
        color: white;
        border: none;
    }
    .btn-action-circle.solid:hover {
        background: var(--purple-mid);
    }
    
    /* Avatar Groups */
    .table-avatar-group {
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .table-avatar {
        width: 32px;
        height: 32px;
        border-radius: 10px;
        object-fit: cover;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
    .table-avatar-initials {
        width: 32px;
        height: 32px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 0.8rem;
    }
    
    /* Remove original minimal header */
    .minimal-top-header {
        position: absolute;
        top: 20px;
        right: 30px;
        z-index: 10;
    }
    
    @media (max-width: 991px) {
        .admin-sidebar {
            display: none;
        }
    }
    {% block admin_custom_styles %}{% endblock %}
</style>
{% endblock %}

{% block body %}
<!-- Admin layout wrapper -->
<div class="admin-wrapper">
    

    <!-- Main Content -->
    <div class="admin-content">
        <!-- Top Banner -->
        <div class="admin-top-banner">
            <div class="d-flex align-items-center">
                <div class="header-icon"><i class="bi bi-briefcase-fill"></i></div>
                <div>
                    <h2>{% block page_title %}Dashboard RH{% endblock %}</h2>
                    <p>{% block page_subtitle %}Gestion et administration{% endblock %}</p>
                </div>
            </div>
            
            <div class="dropdown">
                <button class="btn btn-light rounded-pill border-0 d-flex align-items-center shadow-sm" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="padding: 0.35rem 0.5rem; background: #ffffff;">
                    {% if app.user and app.user.avatarPath %}
                        <img src="{{ asset(app.user.avatarPath) }}" style="width:32px; height:32px; border-radius:50%; object-fit:cover;" class="me-2" alt="Avatar">
                    {% elseif app.user %}
                        <div style="width:32px; height:32px; border-radius:50%; background:var(--purple-dark); display:flex; align-items:center; justify-content:center; color:#fff; font-weight:600; font-size:0.85rem;" class="me-2">
                            {{ app.user.prenom|first|upper }}
                        </div>
                    {% endif %}
                    <span class="fw-medium px-2" style="font-size: 0.9rem; color: #1e293b;">{% if app.user %}{{ app.user.prenom }}{% endif %}</span>
                    <i class="bi bi-chevron-down ms-1 me-2 text-muted" style="font-size: 0.75rem;"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0" style="border-radius: 12px; margin-top: 5px;">
                    <li><h6 class="dropdown-header text-uppercase pb-1" style="font-size:0.7rem; letter-spacing:0.05em;">Connecté en tant que RH</h6></li>
                    <li><span class="dropdown-item-text fw-medium text-dark pb-2 border-bottom mb-2">{% if app.user %}{{ app.user.fullName }}{% endif %}</span></li>
                    <li><a class="dropdown-item pb-2 pt-2 text-danger" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right me-2"></i> Déconnexion</a></li>
                </ul>
            </div>
        </div>

        <div class="admin-main-px">
            {% block admin_content %}{% endblock %}
        </div>
    </div> <!-- End Main Content -->
</div> <!-- End Admin Wrapper -->
{% endblock %}
