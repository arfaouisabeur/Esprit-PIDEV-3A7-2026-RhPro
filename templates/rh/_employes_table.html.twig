<table class="table table-hover mb-0">
    <thead>
        <tr>
            <th>Nom</th>
            <th>Email</th>
            <th>Matricule</th>
            <th>Poste</th>
            <th>Date d'embauche</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {% for employe in employes %}
            <tr>
                <td>
                    <div class="d-flex align-items-center">
                        {% if employe.avatarPath %}
                            <img src="{{ asset(employe.avatarPath) }}" class="avatar me-2" alt="" style="width:40px;height:40px;border-radius:50%;object-fit:cover;">
                        {% else %}
                            <div class="avatar bg-success text-white d-flex align-items-center justify-content-center me-2" style="width:40px;height:40px;border-radius:50%;">
                                {{ employe.prenom|first|upper }}
                            </div>
                        {% endif %}
                        <span class="fw-medium">{{ employe.fullName }}</span>
                    </div>
                </td>
                <td>{{ employe.email }}</td>
                <td><span class="badge bg-secondary">{{ employe.employe.matricule|default('-') }}</span></td>
                <td>{{ employe.employe.position|default('-') }}</td>
                <td>{{ employe.employe.dateEmbauche ? employe.employe.dateEmbauche|date('d/m/Y') : '-' }}</td>
                <td>
                    <a href="{{ path('app_rh_user_view', {'id': employe.id}) }}" class="btn btn-sm btn-outline-info" title="Voir">
                        <i class="bi bi-eye"></i>
                    </a>
                  <form method="post" action="{{ path('app_rh_user_toggle_statut', {'id': employe.id}) }}" class="d-inline"
      onsubmit="return confirm('Changer le statut de cet employé ?')">
    <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ employe.id) }}">
    <input type="hidden" name="redirect" value="employes">  {# ✅ ajout #}
    {% if employe.statut == 'actif' %}
        <button class="btn btn-sm btn-outline-warning" title="Désactiver">
            <i class="bi bi-person-check"></i>
        </button>
    {% else %}
        <button class="btn btn-sm btn-danger" title="Activer">
            <i class="bi bi-person-x text-white"></i>
        </button>
    {% endif %}
</form>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6" class="text-center py-4 text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                    Aucun employé trouvé
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>
