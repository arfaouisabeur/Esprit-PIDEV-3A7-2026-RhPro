{% extends 'base.html.twig' %}

{% block body %}
<div class="container py-5">

    <!-- 🔥 HEADER -->
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="header-icon">✏</div>
        <div>
            <h1 class="header-title">Edit Contract</h1>
            <p class="header-subtitle">Update contract information</p>
        </div>
    </div>

    <!-- 💎 CARD -->
    <div class="form-card">

{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

        <!-- 🔴 GLOBAL ERRORS -->
        <div class="text-danger mb-3">
            {{ form_errors(form) }}
        </div>

        <!-- 👤 EMPLOYEE (LOCKED) -->
        <div class="mb-4">
            <label class="form-label">👤 Employee</label>

            <div class="employee-box">
                {{ contract.employe.user.fullName }}
                <span class="badge-id">
                    {{ contract.employe.matricule }}
                </span>
            </div>
        </div>

        <div class="row g-4">

            <!-- 📅 START -->
            <div class="col-md-6">
                <label class="form-label">Start Date</label>
                {{ form_widget(form.date_debut, {'attr': {'class': 'form-control modern-input'}}) }}
                <div class="text-danger small">{{ form_errors(form.date_debut) }}</div>
            </div>

            <!-- 📅 END -->
            <div class="col-md-6">
                <label class="form-label">End Date</label>
                {{ form_widget(form.date_fin, {'attr': {'class': 'form-control modern-input'}}) }}
                <div class="text-danger small">{{ form_errors(form.date_fin) }}</div>
            </div>

            <!-- TYPE -->
            <div class="col-md-6">
                <label class="form-label">Type</label>
                {{ form_widget(form.type, {'attr': {'class': 'form-control modern-input'}}) }}
                <div class="text-danger small">{{ form_errors(form.type) }}</div>
            </div>

            <!-- STATUS -->
            <div class="col-md-6">
                <label class="form-label">Status</label>
                {{ form_widget(form.statut, {'attr': {'class': 'form-control modern-input'}}) }}
                <div class="text-danger small">{{ form_errors(form.statut) }}</div>
            </div>

            <!-- 💰 SALARY -->
            <div class="col-md-6">
                <label class="form-label">Salary</label>
                <div class="input-group">
                    {{ form_widget(form.salaire_base, {'attr': {'class': 'form-control modern-input'}}) }}
                    <span class="input-group-text">DT</span>
                </div>
                <div class="text-danger small">{{ form_errors(form.salaire_base) }}</div>
            </div>

            <!-- 📝 DESCRIPTION -->
            <div class="col-md-12">
                <label class="form-label">Description</label>
                {{ form_widget(form.description, {'attr': {'class': 'form-control modern-input'}}) }}
                <div class="text-danger small">{{ form_errors(form.description) }}</div>
            </div>

        </div>

        <!-- 🔥 BUTTON -->
        <div class="text-end mt-4">
            <button class="btn btn-main">💾 Update</button>
        </div>

        {{ form_end(form) }}

    </div>

</div>

<!-- 🔥 REAL-TIME VALIDATION -->
<script>
const start = document.querySelector('[name$="[date_debut]"]');
const end = document.querySelector('[name$="[date_fin]"]');
const salary = document.querySelector('[name$="[salaire_base]"]');
const type = document.querySelector('[name$="[type]"]');

function showError(input, message) {
    let error = input.parentElement.querySelector('.live-error');

    if (!error) {
        error = document.createElement('div');
        error.className = 'text-danger small live-error';
        input.parentElement.appendChild(error);
    }

    error.innerText = message;
}

function clearError(input) {
    const error = input.parentElement.querySelector('.live-error');
    if (error) error.remove();
}

// DATE CHECK
function validateDates() {
    clearError(end);

    if (!start.value || !end.value) return;

    if (new Date(end.value) <= new Date(start.value)) {
        showError(end, "End date must be after start date");
    }
}

start.addEventListener('change', validateDates);
end.addEventListener('change', validateDates);

// SALARY
salary.addEventListener('input', () => {
    clearError(salary);
    if (salary.value && parseFloat(salary.value) <= 0) {
        showError(salary, "Salary must be positive");
    }
});

// TYPE
type.addEventListener('input', () => {
    clearError(type);
    if (type.value.length > 0 && type.value.length < 3) {
        showError(type, "Min 3 characters");
    }
});

// SUBMIT BLOCK
document.querySelector('form').addEventListener('submit', function(e) {

    let hasError = false;

    document.querySelectorAll('.live-error').forEach(el => el.remove());

    if (!start.value || !end.value || new Date(end.value) <= new Date(start.value)) {
        showError(end, "Invalid dates");
        hasError = true;
    }

    if (!salary.value || parseFloat(salary.value) <= 0) {
        showError(salary, "Invalid salary");
        hasError = true;
    }

    if (!type.value || type.value.length < 3) {
        showError(type, "Invalid type");
        hasError = true;
    }

    if (hasError) e.preventDefault();
});
</script>

<style>
body { background: #f6f4fb !important; }

.header-icon {
    width: 55px; height: 55px; border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 24px;
    background: linear-gradient(135deg, #7b2ff7, #a044ff);
    color: white;
}

.header-title {
    font-size: 2rem; font-weight: 800;
    background: linear-gradient(135deg, #7b2ff7, #a044ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.form-card {
    background: white;
    border-radius: 20px;
    padding: 30px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.05);
}

.modern-input {
    border-radius: 12px;
    border: 1px solid #eee;
}

.btn-main {
    background: linear-gradient(135deg, #7b2ff7, #a044ff);
    color: white;
    border-radius: 25px;
    padding: 10px 25px;
}
</style>

{% endblock %}