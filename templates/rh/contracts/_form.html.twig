<div class="container py-5">

    <!-- 🔥 HEADER -->
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="header-icon">📄</div>
        <div>
            <h1 class="header-title">
                {{ form.vars.value.id ? 'Edit Contract' : 'Create Contract' }}
            </h1>
            <p class="header-subtitle">
                {{ form.vars.value.id ? 'Update contract information' : 'Create a new employee contract' }}
            </p>
        </div>
    </div>

    <!-- 💎 FORM CARD -->
    <div class="form-card">

        <!-- ❗ GLOBAL ERRORS -->
        <div class="text-danger mb-3">
            {{ form_errors(form) }}
        </div>

        <div class="row g-4">

            <!-- 👤 EMPLOYEE SEARCH -->
            <div class="col-md-12 position-relative">
                <label class="form-label">👤 Employee</label>

                <input type="text" id="employeeSearch"
                       class="form-control modern-input"
                       placeholder="🔍 Search employee...">

                <small id="selectedEmployee" class="status-text"></small>

                <div id="results" class="list-group position-absolute w-100 mt-1"></div>

                <!-- hidden select -->
                <div style="display:none;">
                    {{ form_widget(form.employe) }}
                </div>

                <!-- 🔥 ERROR -->
                <div class="text-danger small">
                    {{ form_errors(form.employe) }}
                </div>
            </div>

            <!-- 📅 START -->
            <div class="col-md-6">
                <label class="form-label">Start Date</label>
                {{ form_widget(form.date_debut, {'attr': {'class': 'form-control modern-input'}}) }}
                <div class="text-danger small">
                    {{ form_errors(form.date_debut) }}
                </div>
            </div>

            <!-- 📅 END -->
            <div class="col-md-6">
                <label class="form-label">End Date</label>
                {{ form_widget(form.date_fin, {'attr': {'class': 'form-control modern-input'}}) }}
                <div class="text-danger small">
                    {{ form_errors(form.date_fin) }}
                </div>
            </div>

            <!-- TYPE -->
            <div class="col-md-6">
                <label class="form-label">Type</label>
                {{ form_widget(form.type, {'attr': {'class': 'form-control modern-input'}}) }}
                <div class="text-danger small">
                    {{ form_errors(form.type) }}
                </div>
            </div>

            <!-- STATUS -->
            <div class="col-md-6">
                <label class="form-label">Status</label>
                {{ form_widget(form.statut, {'attr': {'class': 'form-control modern-input'}}) }}
                <div class="text-danger small">
                    {{ form_errors(form.statut) }}
                </div>
            </div>

            <!-- 💰 SALARY -->
            <div class="col-md-6">
                <label class="form-label">Salary</label>
                <div class="input-group">
                    {{ form_widget(form.salaire_base, {'attr': {'class': 'form-control modern-input'}}) }}
                    <span class="input-group-text">DT</span>
                </div>
                <div class="text-danger small">
                    {{ form_errors(form.salaire_base) }}
                </div>
            </div>

            <!-- 📝 DESCRIPTION -->
            <div class="col-md-12">
                <label class="form-label">Description</label>
                {{ form_widget(form.description, {'attr': {'class': 'form-control modern-input'}}) }}
                <div class="text-danger small">
                    {{ form_errors(form.description) }}
                </div>
            </div>

        </div>

        <!-- 🔥 BUTTON -->
        <div class="text-end mt-4">
            <button class="btn btn-main">💾 Save</button>
        </div>

    </div>

</div>

{{ form_end(form) }}


<script>
// 🔥 REAL-TIME VALIDATION

function showError(input, message) {
    let error = input.parentElement.querySelector('.live-error');

    if (!error) {
        error = document.createElement('div');
        error.className = 'text-danger small live-error mt-1';
        input.parentElement.appendChild(error);
    }

    error.innerText = message;
}

function clearError(input) {
    const error = input.parentElement.querySelector('.live-error');
    if (error) error.remove();
}

// 📅 DATE VALIDATION
const startDate = document.querySelector('[name$="[date_debut]"]');
const endDate = document.querySelector('[name$="[date_fin]"]');

function validateDates() {
    clearError(endDate);

    if (!startDate.value || !endDate.value) return;

    const start = new Date(startDate.value);
    const end = new Date(endDate.value);

    if (end <= start) {
        showError(endDate, "End date must be after start date");
    }
}

startDate.addEventListener('change', validateDates);
endDate.addEventListener('change', validateDates);

// 💰 SALARY VALIDATION
const salary = document.querySelector('[name$="[salaire_base]"]');

salary.addEventListener('input', () => {
    clearError(salary);

    if (!salary.value) return;

    if (parseFloat(salary.value) <= 0) {
        showError(salary, "Salary must be positive");
    }
});

// 📝 TYPE VALIDATION
const type = document.querySelector('[name$="[type]"]');

type.addEventListener('input', () => {
    clearError(type);

    if (type.value.length > 0 && type.value.length < 3) {
        showError(type, "Minimum 3 characters");
    }
});

// 🔥 FINAL SUBMIT BLOCK (IMPORTANT)
document.querySelector('form').addEventListener('submit', function(e) {

    let hasError = false;

    // reset
    document.querySelectorAll('.live-error').forEach(el => el.remove());

    // check salary
    if (!salary.value || parseFloat(salary.value) <= 0) {
        showError(salary, "Invalid salary");
        hasError = true;
    }

    // check type
    if (!type.value || type.value.length < 3) {
        showError(type, "Invalid type");
        hasError = true;
    }

    // check dates
    if (!startDate.value || !endDate.value) {
        showError(endDate, "Dates required");
        hasError = true;
    } else {
        const start = new Date(startDate.value);
        const end = new Date(endDate.value);

        if (end <= start) {
            showError(endDate, "End date must be after start date");
            hasError = true;
        }
    }

    if (hasError) {
        e.preventDefault();
    }
});
</script>
<!-- 🔥 SCRIPT -->
<script>
const input = document.getElementById('employeeSearch');
const results = document.getElementById('results');
const hiddenSelect = document.getElementById('{{ form.employe.vars.id }}');
const selectedText = document.getElementById('selectedEmployee');

// 🔁 FIX EDIT PREFILL
window.addEventListener('DOMContentLoaded', () => {
    const selectedOption = hiddenSelect.options[hiddenSelect.selectedIndex];

    if (selectedOption && selectedOption.value) {
        input.value = selectedOption.text;
        hiddenSelect.value = selectedOption.value;
        selectedText.innerText = "✔ " + selectedOption.text;
        selectedText.style.color = "green";
    }
});

// 🔍 SEARCH
input.addEventListener('input', function() {

    const value = this.value.toLowerCase();
    results.innerHTML = '';

    Array.from(hiddenSelect.options).forEach(option => {

        if (!option.value) return;

        if (option.text.toLowerCase().includes(value)) {

            const item = document.createElement('a');
            item.className = 'list-group-item list-group-item-action';
            item.textContent = option.text;

            item.onclick = async () => {

                input.value = option.text;
                hiddenSelect.value = option.value;

                hiddenSelect.dispatchEvent(new Event('change'));

                try {
                    const response = await fetch('/rh/contracts/check-active/' + option.value);
                    const data = await response.json();

                    if (data.hasActive) {
                        selectedText.innerHTML = "❌ Already has active contract";
                        selectedText.style.color = "#dc2626";
                    } else {
                        selectedText.innerHTML = "✔ Available";
                        selectedText.style.color = "#16a34a";
                    }

                } catch (e) {
                    selectedText.innerHTML = "⚠ Error checking";
                    selectedText.style.color = "orange";
                }

                results.innerHTML = '';
            };

            results.appendChild(item);
        }

    });

});

// 🔥 SAFE SUBMIT
document.querySelector('form').addEventListener('submit', function(e) {

    if (!hiddenSelect.value || hiddenSelect.value === "") {
        e.preventDefault();
        alert('⚠ Please select an employee!');
    }

});
</script>


