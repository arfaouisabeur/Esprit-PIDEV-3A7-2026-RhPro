{% extends 'base.html.twig' %}

{% block body %}
<div class="container py-5">

    <!-- 🔥 HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-5">

        <div class="header-block">
            <div class="header-icon">📄</div>
            <div>
                <h1 class="header-title">Contracts</h1>
                <p class="header-subtitle">Manage employee contracts</p>
            </div>
        </div>

        <a href="{{ path('app_rh_contract_new') }}" class="btn btn-main">
            + New Contract
        </a>

    </div>

    <!-- 🔍 FILTER -->
    <div class="filter-card mb-4">

        <div class="row g-3">

            <div class="col-md-6">
                <input type="text" id="searchInput"
                       class="modern-input"
                       placeholder="🔍 Search by matricule or name...">
            </div>

            <div class="col-md-4">
                <select id="statusFilter" class="modern-input">
                    <option value="">All</option>
                    <option value="active">Active</option>
                    <option value="expired">Expired</option>
                </select>
            </div>

        </div>

    </div>

    <!-- 💎 TABLE -->
    <div class="table-card">

        <div class="table-header-top">
            <h5 class="mb-0">📊 Contracts List</h5>
        </div>

        <div class="table-responsive">

            <table class="table align-middle mb-0">

                <thead>
                    <tr>
                        <th>Employé</th>
                        <th>Start</th>
                        <th>End</th>
                        <th>Status</th>
                        <th>Salary</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>
                {% for contract in contracts %}
                    <tr 
                        data-name="{{ (contract.employe.matricule ~ ' ' ~ contract.employe.user.fullName)|lower }}"
                        data-status="{% if contract.dateFin and contract.dateFin < "now"|date('Y-m-d') %}expired{% else %}active{% endif %}"
                    >

                        <!-- 👤 EMPLOYEE -->
                        <td>
                            <strong>{{ contract.employe.user.fullName }}</strong><br>
                            <small class="text-muted">
                                {{ contract.employe.matricule }}
                            </small>
                        </td>

                        <!-- 📅 DATES -->
                        <td>{{ contract.dateDebut|date('d/m/Y') }}</td>
                        <td>{{ contract.dateFin ? contract.dateFin|date('d/m/Y') : '-' }}</td>

                       <td>
    {% if contract.statut == 'SUSPENDU' %}
        <span class="badge" style="background:#fef3c7; color:#d97706;">Suspendu</span>

    {% elseif contract.dateFin and contract.dateFin < "now"|date('Y-m-d') %}
        <span class="badge red">Expiré</span>

    {% else %}
        <span class="badge green">Actif</span>
    {% endif %}
</td>

                        <!-- 💰 SALARY -->
                        <td>
                            <span class="badge-amount">
                                {{ contract.salaireBase }} DT
                            </span>
                        </td>

                        <!-- ⚙ ACTIONS -->
                        <td class="d-flex gap-2">

                            <a href="{{ path('app_rh_contract_edit', {'id': contract.id}) }}"
                               class="action-btn edit">
                                ✏
                            </a>

                            <form method="post"
                                  action="{{ path('app_rh_contract_delete', {'id': contract.id}) }}"
                                  onsubmit="return confirm('Delete this contract?');">

                                <input type="hidden" name="_token"
                                       value="{{ csrf_token('delete' ~ contract.id) }}">

                                <button class="action-btn delete">🗑</button>
                            </form>

                        </td>

                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="empty-state">
                            📄 No contracts found
                        </td>
                    </tr>
                {% endfor %}
                </tbody>

            </table>

        </div>

    </div>

</div>

<!-- 🔥 FILTER SCRIPT -->
<script>
const searchInput = document.getElementById('searchInput');
const statusFilter = document.getElementById('statusFilter');
const rows = document.querySelectorAll('tbody tr');

function filterTable() {
    const search = searchInput.value.toLowerCase();
    const status = statusFilter.value;

    rows.forEach(row => {
        const name = row.dataset.name;
        const rowStatus = row.dataset.status;

        let matchSearch = name.includes(search);
        let matchStatus = !status || rowStatus === status;

        row.style.display = (matchSearch && matchStatus) ? '' : 'none';
    });
}

searchInput.addEventListener('input', filterTable);
statusFilter.addEventListener('change', filterTable);
</script>

<style>

/* 🌸 BACKGROUND FIX */
body {
    background: #f6f4fb !important;
}

/* 🔥 HEADER */
.header-block {
    display: flex;
    align-items: center;
    gap: 15px;
}

.header-icon {
    width: 55px;
    height: 55px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
    background: linear-gradient(135deg, #7b2ff7, #a044ff);
    color: white;
}

.header-title {
    font-size: 2rem;
    font-weight: 800;
    margin: 0;
    background: linear-gradient(135deg, #7b2ff7, #a044ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.header-subtitle {
    margin: 0;
    color: #6b7280;
}

/* FILTER */
.filter-card {
    background: white;
    padding: 15px;
    border-radius: 18px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
}

.modern-input {
    width: 100%;
    padding: 10px;
    border-radius: 12px;
    border: 1px solid #eee;
}

/* TABLE */
.table-card {
    background: white;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 20px 50px rgba(0,0,0,0.05);
}

.table-header-top {
    padding: 15px;
    border-bottom: 1px solid #eee;
}

.table thead {
    background: #f4f0ff;
    color: #7b2ff7;
}

/* BADGES */
.badge.green {
    background: #dcfce7;
    color: #16a34a;
    padding: 5px 12px;
    border-radius: 20px;
}

.badge.red {
    background: #fee2e2;
    color: #dc2626;
    padding: 5px 12px;
    border-radius: 20px;
}

/* SALARY */
.badge-amount {
    background: #dcfce7;
    color: #16a34a;
    padding: 6px 12px;
    border-radius: 20px;
    font-weight: 600;
}

/* ACTIONS */
.action-btn {
    border: none;
    background: #f3f0ff;
    padding: 6px 10px;
    border-radius: 10px;
}

.action-btn.edit:hover {
    background: #7b2ff7;
    color: white;
}

.action-btn.delete:hover {
    background: #ef4444;
    color: white;
}

/* EMPTY */
.empty-state {
    text-align: center;
    padding: 30px;
    color: #6b7280;
}

</style>

{% endblock %}