<table class="table table-hover mb-0">
    <thead>
        <tr>
            <th>Nom</th>
            <th>Email</th>
            <th>Téléphone</th>
            <th>Niveau d'études</th>
            <th>Expérience</th>
            <th>Matricule</th>
            <th>Position</th>
            <th>Date d'embauche</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {% for candidat in candidats %}
            <tr>
                <td>
                    <div class="d-flex align-items-center">
                        {% if candidat.avatarPath %}
                            <img src="{{ asset(candidat.avatarPath) }}" class="avatar me-2" alt="" style="width:40px;height:40px;border-radius:50%;object-fit:cover;">
                        {% else %}
                            <div class="avatar bg-primary text-white d-flex align-items-center justify-content-center me-2" style="width:40px;height:40px;border-radius:50%;">
                                {{ candidat.prenom|first|upper }}
                            </div>
                        {% endif %}
                        <span class="fw-medium">{{ candidat.fullName }}</span>
                    </div>
                </td>
                <td>{{ candidat.email }}</td>
                <td>{{ candidat.telephone ?: '-' }}</td>
                <td>{{ candidat.candidat is not null ? candidat.candidat.niveauEtude|default('-') : '-' }}</td>
                <td>{{ candidat.candidat is not null ? candidat.candidat.experience|default(0) ~ ' ans' : '-' }}</td>
                <td>
                    <span class="badge bg-secondary">
                        {{ candidat.employe is not null ? candidat.employe.matricule|default('-') : '-' }}
                    </span>
                </td>
                <td>{{ candidat.employe is not null ? candidat.employe.position|default('-') : '-' }}</td>
                <td>
                    {{ candidat.employe is not null and candidat.employe.dateEmbauche is not null
                        ? candidat.employe.dateEmbauche|date('d/m/Y')
                        : '-' }}
                </td>
                <td>
                    <a href="{{ path('app_rh_user_view', {'id': candidat.id}) }}" class="btn btn-sm btn-outline-info" title="Voir">
                        <i class="bi bi-eye"></i>
                    </a>
                     <form method="post" action="{{ path('app_rh_user_toggle_statut', {'id': candidat.id}) }}" class="d-inline"
      onsubmit="return confirm('Changer le statut de ce candidat ?')">
    <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ candidat.id) }}">
    <input type="hidden" name="redirect" value="candidats">  {# ✅ ajout #}
    {% if candidat.statut == 'actif' %}
        <button class="btn btn-sm btn-outline-warning" title="Désactiver">
            <i class="bi bi-person-check"></i>
        </button>
    {% else %}
        <button class="btn btn-sm btn-danger" title="Activer">
            <i class="bi bi-person-x text-white"></i>
        </button>
    {% endif %}
</form>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="9" class="text-center py-4 text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                    Aucun candidat trouvé
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>
