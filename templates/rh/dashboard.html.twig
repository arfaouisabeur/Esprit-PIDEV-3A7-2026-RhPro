{% extends 'base.html.twig' %}
{% block title %}Dashboard RH — RH Pro{% endblock %}

{% block styles %}
:root { --green: #10b981; --green-dark: #059669; --surface: #f0fdf9; --border: #e5e7eb; --text-dark: #111827; --text-muted: #6b7280; }
body { background: var(--surface); }
.dash { min-height: 100vh; background: var(--surface); font-family: 'Inter', sans-serif; padding: 40px 0 60px; }
.dash-inner { max-width: 1100px; margin: 0 auto; padding: 0 32px; }
.dash-title { font-size: 28px; font-weight: 700; color: var(--green-dark); margin: 0 0 6px; }
.dash-sub { font-size: 14px; color: var(--text-muted); margin: 0 0 32px; }
.user-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
@media(max-width:768px){ .user-grid { grid-template-columns: 1fr; } .dash-inner { padding: 0 16px; } }
.ucard { background: #fff; border-radius: 16px; border: 1px solid var(--border); box-shadow: 0 2px 8px rgba(0,0,0,0.05); overflow: hidden; }
.ucard-header { padding: 18px 22px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
.ucard-title { font-size: 15px; font-weight: 700; color: var(--text-dark); margin: 0; display: flex; align-items: center; gap: 8px; }
.ucard-count { font-size: 12px; font-weight: 700; background: var(--surface); color: var(--green-dark); padding: 2px 10px; border-radius: 100px; }
table.utbl { width: 100%; border-collapse: collapse; }
.utbl th { font-size: 10px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: .05em; padding: 10px 20px; text-align: left; background: #f9fafb; border-bottom: 1px solid var(--border); }
.utbl td { padding: 12px 20px; font-size: 13px; color: var(--text-dark); border-bottom: 1px solid #f3f4f6; vertical-align: middle; }
.utbl tr:last-child td { border-bottom: none; }
.utbl tbody tr:hover td { background: #f9fefb; }
.uav { width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; color: #fff; flex-shrink: 0; }
.urow { display: flex; align-items: center; gap: 10px; }
.unm { font-weight: 600; font-size: 13px; } .uem { font-size: 11px; color: var(--text-muted); }
.bs { display: inline-flex; gap: 4px; align-items: center; padding: 3px 9px; border-radius: 100px; font-size: 11px; font-weight: 600; }
.bs-a { background: #d1fae5; color: #065f46; } .bs-i { background: #fee2e2; color: #991b1b; }
.no-data { text-align: center; padding: 32px; color: var(--text-muted); font-size: 13px; }
.action-row { display: flex; gap: 10px; margin-bottom: 32px; flex-wrap: wrap; }
.btn-action { display: inline-flex; align-items: center; gap: 6px; padding: 10px 18px; border-radius: 10px; font-size: 13px; font-weight: 600; text-decoration: none; transition: background .2s; }
.btn-action-green { background: var(--green); color: #fff; }
.btn-action-green:hover { background: var(--green-dark); color: #fff; text-decoration: none; }
.btn-action-outline { background: #fff; color: var(--text-dark); border: 1px solid var(--border); }
.btn-action-outline:hover { background: var(--surface); text-decoration: none; color: var(--text-dark); }
{% endblock %}

{% block body %}
<div class="dash">
  <div class="dash-inner">
    <h1 class="dash-title">👥 Tableau de bord RH</h1>
    <p class="dash-sub">Gestion des candidats et des employés</p>

    <div class="action-row">
      <a href="{{ path('app_evenement_index') }}" class="btn-action btn-action-green">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Gérer les événements
      </a>
      <a href="{{ path('app_rh_export_pdf', {'type': 'employes'}) }}" class="btn-action btn-action-outline">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        Exporter PDF
      </a>
      <a href="{{ path('app_rh_export_csv', {'type': 'employes'}) }}" class="btn-action btn-action-outline">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        Exporter CSV
      </a>
    </div>

    <div class="user-grid">
      {# Candidats #}
      <div class="ucard">
        <div class="ucard-header">
          <h2 class="ucard-title">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            Candidats
          </h2>
          <span class="ucard-count">{{ candidats|length }}</span>
        </div>
        <table class="utbl">
          <thead><tr><th>Candidat</th><th>Niveau</th><th>Statut</th></tr></thead>
          <tbody>
            {% for u in candidats %}
            <tr>
              <td>
                <div class="urow">
                  <div class="uav" style="background:linear-gradient(135deg,#3b82f6,#2563eb)">{{ u.prenom|first|upper }}</div>
                  <div><div class="unm">{{ u.prenom }} {{ u.nom }}</div><div class="uem">{{ u.email }}</div></div>
                </div>
              </td>
              <td style="font-size:12px;color:var(--text-muted)">{{ u.candidat ? u.candidat.niveauEtude|default('—') : '—' }}</td>
              <td><span class="bs {{ u.statut == 'actif' ? 'bs-a' : 'bs-i' }}">● {{ u.statut == 'actif' ? 'Actif' : 'Inactif' }}</span></td>
            </tr>
            {% else %}
            <tr><td colspan="3" class="no-data">Aucun candidat</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>

      {# Employés #}
      <div class="ucard">
        <div class="ucard-header">
          <h2 class="ucard-title">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
            Employés
          </h2>
          <span class="ucard-count">{{ employes|length }}</span>
        </div>
        <table class="utbl">
          <thead><tr><th>Employé</th><th>Poste</th><th>Statut</th><th>Actions</th></tr></thead>
          <tbody>
            {% for u in employes %}
            <tr>
              <td>
                <div class="urow">
                  <div class="uav">{{ u.prenom|first|upper }}</div>
                  <div><div class="unm">{{ u.prenom }} {{ u.nom }}</div><div class="uem">{{ u.employe ? u.employe.matricule|default('—') : '—' }}</div></div>
                </div>
              </td>
              <td style="font-size:12px;color:var(--text-muted)">{{ u.employe ? u.employe.position|default('—') : '—' }}</td>
              <td><span class="bs {{ u.statut == 'actif' ? 'bs-a' : 'bs-i' }}">● {{ u.statut == 'actif' ? 'Actif' : 'Inactif' }}</span></td>
              <td>
                <div style="display:flex;gap:6px;">
                  <a href="{{ path('app_rh_user_view', {'id': u.id}) }}"
                     style="font-size:11px;font-weight:600;color:#6b7280;border:1px solid var(--border);padding:4px 10px;border-radius:6px;text-decoration:none;display:inline-flex;align-items:center;gap:4px;">
                    Voir
                  </a>
                  <a href="{{ path('app_rh_user_edit', {'id': u.id}) }}"
                     style="font-size:11px;font-weight:600;color:var(--green-dark);background:#d1fae5;padding:4px 10px;border-radius:6px;text-decoration:none;display:inline-flex;align-items:center;gap:4px;">
                    Modifier
                  </a>
                </div>
              </td>
            </tr>
            {% else %}
            <tr><td colspan="4" class="no-data">Aucun employé</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
{% endblock %}
