{% extends 'base.html.twig' %}

{% block body %}
<div class="container py-5">

    <!-- 🔥 HEADER -->
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="header-icon">💰</div>
        <div>
            <h1 class="header-title">Modifier Salaire</h1>
            <p class="header-subtitle">Mettre à jour les informations du salaire</p>
        </div>
    </div>

    <!-- 💎 CARD -->
    <div class="form-card">

        <!-- 👤 EMPLOYEE -->
        <div class="mb-4">
            <label class="form-label">👤 Employé</label>

            <div class="employee-box">
                {{ salaire.contract.employe.user.fullName }}
            </div>
        </div>

        {{ form_start(form) }}

        <!-- GLOBAL ERRORS -->
        <div class="text-danger mb-3">
            {{ form_errors(form) }}
        </div>

        <div class="row g-4">

            <!-- MOIS -->
            <div class="col-md-6">
                <label class="form-label">Mois</label>
                {{ form_widget(form.mois, {'attr': {'class': 'form-control modern-input'}}) }}
                {{ form_errors(form.mois) }}
            </div>

            <!-- ANNEE -->
            <div class="col-md-6">
                <label class="form-label">Année</label>
                {{ form_widget(form.annee, {'attr': {'class': 'form-control modern-input'}}) }}
                {{ form_errors(form.annee) }}
            </div>

            <!-- MONTANT -->
            <div class="col-md-6">
                <label class="form-label">Montant</label>
                <div class="input-group">
                    {{ form_widget(form.montant, {'attr': {'class': 'form-control modern-input'}}) }}
                    <span class="input-group-text">DT</span>
                </div>
                {{ form_errors(form.montant) }}
            </div>

            <!-- STATUT -->
            <div class="col-md-6">
                <label class="form-label">Statut</label>
                {{ form_widget(form.statut, {'attr': {'class': 'form-control modern-input'}}) }}
                {{ form_errors(form.statut) }}
            </div>

            <!-- DATE -->
            <div class="col-md-12">
                <label class="form-label">Date de paiement</label>
                {{ form_widget(form.date_paiement, {'attr': {'class': 'form-control modern-input'}}) }}
                {{ form_errors(form.date_paiement) }}
            </div>

        </div>

        <!-- 🔥 BUTTON -->
        <div class="text-end mt-4">
            <button class="btn btn-main">💾 Mettre à jour</button>
        </div>

        {{ form_end(form) }}

    </div>

</div>

<!-- 🔥 REAL-TIME VALIDATION (UNCHANGED) -->
<script>
const montant = document.querySelector('[name$="[montant]"]');
const annee = document.querySelector('[name$="[annee]"]');

function showError(input, message) {
    let error = input.parentElement.querySelector('.live-error');

    if (!error) {
        error = document.createElement('div');
        error.className = 'text-danger small live-error';
        input.parentElement.appendChild(error);
    }

    error.innerText = message;
}

function clearError(input) {
    const error = input.parentElement.querySelector('.live-error');
    if (error) error.remove();
}

montant.addEventListener('input', () => {
    clearError(montant);
    if (montant.value && parseFloat(montant.value) <= 0) {
        showError(montant, "Montant doit être positif");
    }
});

annee.addEventListener('input', () => {
    clearError(annee);
    if (annee.value && (annee.value < 2000 || annee.value > 2100)) {
        showError(annee, "Année invalide");
    }
});

document.querySelector('form').addEventListener('submit', function(e) {

    let hasError = false;

    document.querySelectorAll('.live-error').forEach(el => el.remove());

    if (!montant.value || parseFloat(montant.value) <= 0) {
        showError(montant, "Montant invalide");
        hasError = true;
    }

    if (!annee.value || annee.value < 2000 || annee.value > 2100) {
        showError(annee, "Année invalide");
        hasError = true;
    }

    if (hasError) e.preventDefault();
});
</script>

<style>

/* 🌸 BACKGROUND */
body {
    background: #f6f4fb !important;
}

/* HEADER */
.header-icon {
    width: 55px;
    height: 55px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
    background: linear-gradient(135deg, #7b2ff7, #a044ff);
    color: white;
}

.header-title {
    font-size: 2rem;
    font-weight: 800;
    background: linear-gradient(135deg, #7b2ff7, #a044ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.header-subtitle {
    color: #6b7280;
}

/* CARD */
.form-card {
    background: white;
    border-radius: 20px;
    padding: 30px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.05);
}

/* EMPLOYEE BOX */
.employee-box {
    background: #f4f0ff;
    padding: 12px 16px;
    border-radius: 12px;
    font-weight: 600;
}

/* INPUT */
.modern-input {
    border-radius: 12px;
    border: 1px solid #eee;
    padding: 10px;
}

.modern-input:focus {
    border-color: #7b2ff7;
    box-shadow: 0 0 0 3px rgba(123,47,247,0.1);
}

/* BUTTON */
.btn-main {
    background: linear-gradient(135deg, #7b2ff7, #a044ff);
    border: none;
    color: white;
    border-radius: 25px;
    padding: 10px 25px;
    font-weight: 600;
    box-shadow: 0 10px 25px rgba(123,47,247,0.3);
}

.btn-main:hover {
    transform: translateY(-2px);
}

</style>

{% endblock %}