{% extends 'base.html.twig' %}

{% block body %}
<div class="container py-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="header-block">
    <div class="header-icon">💰</div>
    <div>
        <h1 class="header-title">Salaires</h1>
        <p class="header-subtitle">Gérez les salaires des employés</p>
    </div>
</div>

        <a href="{{ path('app_rh_salaire_new') }}" class="btn btn-main">
            + Nouveau
        </a>
    </div>

    <!-- MAIN CARD -->
    <div class="rh-card">

        <!-- FILTER BAR -->
        <div class="filter-row">

            <div class="filter-item">
                <label>Rechercher</label>
                <input id="search" type="text" placeholder="Saisir un nom...">
            </div>

            <div class="filter-item">
                <label>Mois</label>
                <select id="mois">
                    <option value="">Tous</option>
                    {% for m in 1..12 %}
                        <option value="{{ m }}">
                            {{ [
                                'Jan','Fév','Mar','Avr','Mai','Juin',
                                'Juil','Août','Sep','Oct','Nov','Déc'
                            ][m-1] }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div class="filter-item">
                <label>Statut</label>
                <select id="statut">
                    <option value="">Tous</option>
                    <option value="PAYE">Payé</option>
                    <option value="EN_ATTENTE">En attente</option>
                </select>
            </div>

        </div>

        <!-- TABLE -->
        <table class="rh-table" id="table">

            <thead>
                <tr>
                    <th>EMPLOYÉ</th>
                    <th>MOIS</th>
                    <th>MONTANT</th>
                    <th>STATUT</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
            {% for salaire in salaires %}
                <tr 
                    data-name="{{ salaire.contract.employe.user.fullName|lower }}"
                    data-mois="{{ salaire.mois }}"
                    data-statut="{{ salaire.statut }}"
                >

                    <td class="name">
                        {{ salaire.contract.employe.user.fullName }}
                    </td>

                    <td>
                        {{ [
                            'Jan','Fév','Mar','Avr','Mai','Juin',
                            'Juil','Août','Sep','Oct','Nov','Déc'
                        ][salaire.mois-1] }}
                    </td>

                    <td class="amount">
                        {{ salaire.montant }} DT
                    </td>

                    <td>
                        {% if salaire.statut == 'PAYE' %}
                            <span class="badge green">Payé</span>
                        {% else %}
                            <span class="badge orange">En attente</span>
                        {% endif %}
                    </td>

                    <td class="actions">

                        <a href="{{ path('app_rh_salaire_edit', {'id': salaire.id}) }}">
                            ✏
                        </a>

                        <form method="post"
                              action="{{ path('app_rh_salaire_delete', {'id': salaire.id}) }}"
                              onsubmit="return confirm('Supprimer ?');">

                            <input type="hidden" name="_token"
                                   value="{{ csrf_token('delete' ~ salaire.id) }}">

                            <button>🗑</button>
                        </form>

                    </td>

                </tr>
            {% endfor %}
            </tbody>

        </table>

    </div>

</div>

<style>


/* HEADER BLOCK */
.header-block {
    display: flex;
    align-items: center;
    gap: 15px;
}

/* ICON */
.header-icon {
    width: 55px;
    height: 55px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;

    background: linear-gradient(135deg, #7b2ff7, #a044ff);
    color: white;

    box-shadow: 0 10px 25px rgba(123, 47, 247, 0.3);
}

/* TITLE 🔥 */
.header-title {
    font-size: 2rem;
    font-weight: 800;
    margin: 0;

    background: linear-gradient(135deg, #7b2ff7, #a044ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

/* SUBTITLE */
.header-subtitle {
    margin: 0;
    color: #6b7280;
    font-size: 0.95rem;
}
/* HEADER */
.title {
    font-weight: 700;
}

.subtitle {
    color: #6b7280;
}

/* BUTTON */
.btn-main {
    background: linear-gradient(135deg, #7b2ff7, #a044ff);
    color: white;
    border-radius: 20px;
    padding: 8px 18px;
}

/* MAIN CARD */
.rh-card {
    background: #ffffff;
    border-radius: 20px;
    padding: 20px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
}

/* FILTER */
.filter-row {
    display: flex;
    gap: 15px;
    margin-bottom: 20px;
}

.filter-item {
    flex: 1;
}

.filter-item label {
    font-size: 12px;
    color: #888;
}

.filter-item input,
.filter-item select {
    width: 100%;
    padding: 10px;
    border-radius: 12px;
    border: 1px solid #eee;
}

/* TABLE */
.rh-table {
    width: 100%;
    border-collapse: collapse;
}

.rh-table thead th {
    font-size: 12px;
    color: #7b2ff7;
    text-transform: uppercase;
    padding: 12px;
}

.rh-table tbody tr {
    border-top: 1px solid #f0f0f0;
}

.rh-table td {
    padding: 14px;
}

/* TEXT */
.name {
    font-weight: 600;
}

.amount {
    font-weight: 600;
    color: #16a34a;
}

/* BADGES */
.badge {
    padding: 5px 12px;
    border-radius: 20px;
}

.badge.green {
    background: #dcfce7;
    color: #16a34a;
}

.badge.orange {
    background: #fef3c7;
    color: #d97706;
}

/* ACTIONS */
.actions a,
.actions button {
    border: none;
    background: #f3f0ff;
    padding: 6px 10px;
    border-radius: 10px;
    margin-right: 5px;
}

body {
    background: #f6f4fb !important;
}

</style>
<script>
const searchInput = document.getElementById('search');
const moisSelect = document.getElementById('mois');
const statutSelect = document.getElementById('statut');
const rows = document.querySelectorAll('#table tbody tr');

function filterTable() {
    const search = searchInput.value.toLowerCase();
    const mois = moisSelect.value;
    const statut = statutSelect.value;

    rows.forEach(row => {
        const name = row.dataset.name;
        const rowMois = row.dataset.mois;
        const rowStatut = row.dataset.statut;

        let show = true;

        if (search && !name.includes(search)) {
            show = false;
        }

        if (mois && mois !== rowMois) {
            show = false;
        }

        if (statut && statut !== rowStatut) {
            show = false;
        }

        row.style.display = show ? '' : 'none';
    });
}

// 🔥 EVENTS
searchInput.addEventListener('input', filterTable);
moisSelect.addEventListener('change', filterTable);
statutSelect.addEventListener('change', filterTable);
</script>
{% endblock %}