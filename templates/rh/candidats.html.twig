{% extends 'rh/layout_rh.html.twig' %}

{% block title %}Gestion Candidats - RH{% endblock %}

{% block rh_content %}

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="fw-bold mb-0">
                        <i class="bi bi-people me-2 text-primary"></i>Gestion des Candidats
                    </h2>
                    <div>
                        <a href="{{ path('app_rh_export_pdf', {'type': 'candidats'}) }}" class="btn btn-outline-danger me-2">
                            <i class="bi bi-file-earmark-pdf me-2"></i>PDF
                        </a>
                        <a href="{{ path('app_rh_export_csv', {'type': 'candidats'}) }}" class="btn btn-outline-success me-2">
                            <i class="bi bi-file-earmark-excel me-2"></i>Excel
                        </a>
                    </div>
                </div>

                <!-- Search Bar - Realtime -->
                <div class="card mb-4">
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                                    <input type="text" id="searchInput" class="form-control" placeholder="Rechercher en temps réel par nom, prénom ou email..." value="{{ search }}">
                                    <span class="input-group-text" id="loadingSpinner" style="display:none;">
                                        <div class="spinner-border spinner-border-sm" role="status"></div>
                                    </span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <select id="sortSelect" class="form-select">
                                    <option value="id" {{ sort == 'id' ? 'selected' : '' }}>Trier par ID</option>
                                    <option value="nom" {{ sort == 'nom' ? 'selected' : '' }}>Trier par Nom</option>
                                    <option value="prenom" {{ sort == 'prenom' ? 'selected' : '' }}>Trier par Prénom</option>
                                    <option value="email" {{ sort == 'email' ? 'selected' : '' }}>Trier par Email</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <select id="orderSelect" class="form-select">
                                    <option value="ASC" {{ order == 'ASC' ? 'selected' : '' }}>Croissant ↑</option>
                                    <option value="DESC" {{ order == 'DESC' ? 'selected' : '' }}>Décroissant ↓</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-body p-0">
                        <div class="table-responsive" id="tableContainer">
                            {% include 'rh/_candidats_table.html.twig' with {'candidats': candidats} %}
                        </div>
                    </div>
                </div>


<script>
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('searchInput');
    const sortSelect = document.getElementById('sortSelect');
    const orderSelect = document.getElementById('orderSelect');
    const tableContainer = document.getElementById('tableContainer');
    const loadingSpinner = document.getElementById('loadingSpinner');
    
    if (!searchInput || !tableContainer) {
        console.error('Elements not found:', {searchInput, tableContainer});
        return;
    }
    
    let searchTimeout;
    
    function updateTable() {
        const search = searchInput.value;
        const sort = sortSelect ? sortSelect.value : 'id';
        const order = orderSelect ? orderSelect.value : 'DESC';
        
        console.log('Updating table:', {search, sort, order});
        
        if (loadingSpinner) loadingSpinner.style.display = 'block';
        
        const url = `{{ path('app_rh_candidats') }}?search=${encodeURIComponent(search)}&sort=${sort}&order=${order}`;
        console.log('Fetching URL:', url);
        
        fetch(url, {
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => {
            console.log('Response status:', response.status);
            if (!response.ok) throw new Error('Network response was not ok');
            return response.text();
        })
        .then(html => {
            console.log('Received HTML length:', html.length);
            tableContainer.innerHTML = html;
            if (loadingSpinner) loadingSpinner.style.display = 'none';
        })
        .catch(error => {
            console.error('Error updating table:', error);
            if (loadingSpinner) loadingSpinner.style.display = 'none';
        });
    }
    
    searchInput.addEventListener('input', function(e) {
        console.log('Input event:', e.target.value);
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(updateTable, 300);
    });
    
    if (sortSelect) {
        sortSelect.addEventListener('change', function() {
            console.log('Sort changed:', this.value);
            updateTable();
        });
    }
    
    if (orderSelect) {
        orderSelect.addEventListener('change', function() {
            console.log('Order changed:', this.value);
            updateTable();
        });
    }
    
    console.log('Real-time search initialized');
});
</script>
{% endblock %}
