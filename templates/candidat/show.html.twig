{% extends 'base.html.twig' %}

{% block title %}Candidat{% endblock %}

{% block body %}
    <h1>Candidat</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Niveau_etude</th>
                <td>{{ candidat.niveauEtude ?? 'N/A' }}</td>
            </tr>
            <tr>
                <th>Experience</th>
                <td>{{ candidat.experience ?? 'N/A' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_candidat_index') }}">back to list</a>

    {% if candidat.id %}
        <a href="{{ path('app_candidat_edit', {'id': candidat.id}) }}">edit</a>
    {% endif %}

    {{ include('candidat/_delete_form.html.twig') }}
{% endblock %}