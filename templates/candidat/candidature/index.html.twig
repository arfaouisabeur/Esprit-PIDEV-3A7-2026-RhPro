{% extends 'candidat/base.html.twig' %}

{% block title %}Mes candidatures{% endblock %}

{% block body %}
<div class="page-header">
    <div>
        <h1 class="page-title">
            <i class="bi bi-file-earmark-text-fill"></i>
            Mes candidatures
        </h1>
        <p class="page-subtitle">Suivez l’historique des offres auxquelles vous avez postulé.</p>
    </div>

    <div class="header-actions">
        <a href="{{ path('candidat_offres') }}" class="btn btn-main">
            <i class="bi bi-plus-circle me-2"></i>Voir les offres
        </a>
    </div>
</div>

<div class="panel">
    <div class="panel-head">
        <h2 class="panel-title">
            <i class="bi bi-clock-history"></i>
            Historique des candidatures
        </h2>
    </div>

    <div class="panel-body">
        <div class="table-responsive">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Offre</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for c in candidatures %}
                    <tr>
                        <td>{{ c.dateCandidature ? c.dateCandidature|date('d/m/Y') : '-' }}</td>
                        <td>{{ c.offreEmploi.titre }}</td>
                        <td>
                            {% if c.statut is defined and c.statut == 'acceptée' %}
                                <span class="badge-soft badge-accepted">Acceptée</span>
                            {% elseif c.statut is defined and c.statut == 'refusée' %}
                                <span class="badge-soft badge-rejected">Refusée</span>
                            {% else %}
                                <span class="badge-soft badge-pending">En attente</span>
                            {% endif %}
                        </td>
                        <td>
                            <a href="{{ path('candidat_offre_show', {'id': c.offreEmploi.id}) }}" class="action-circle" title="Voir">
                                <i class="bi bi-eye-fill"></i>
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4">
                            <div class="empty-box">
                                <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                                Aucune candidature trouvée.
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
