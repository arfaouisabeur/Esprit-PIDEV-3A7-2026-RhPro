{% extends 'base.html.twig' %}

{% block title %}Board Tâches | {{ projet.titre }} | RH Pro{% endblock %}

{% block stylesheets %}
<style>
    :root {
        --board-bg: #f8fafc;
        --column-bg: rgba(226, 232, 240, 0.4);
        --card-bg: #ffffff;
        --accent-purple: #5b2b82;
        --accent-purple-light: #7c3dac;
        --text-main: #1e293b;
        --text-muted: #64748b;
        
        --color-todo: #94a3b8;
        --color-doing: #3b82f6;
        --color-done: #10b981;
        --color-blocked: #ef4444;
    }

    body, html, main {
        background-color: var(--board-bg) !important;
        color: var(--text-main);
    }

    .kanban-wrapper {
        padding: 3rem 2rem;
        max-width: 1600px;
        margin: 0 auto;
        animation: fadeIn 0.6s ease-out;
    }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    /* --- HEADER --- */
    .kanban-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 3rem;
        gap: 2rem;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--accent-purple);
        text-decoration: none;
        font-weight: 700;
        font-size: 0.9rem;
        margin-bottom: 0.75rem;
        transition: opacity 0.2s;
    }

    .back-btn:hover { opacity: 0.7; }

    .kanban-header h1 {
        font-family: 'Playfair Display', serif;
        font-size: 2.25rem;
        font-weight: 700;
        margin: 0;
        color: var(--accent-purple);
    }

    .kanban-header h1 span { color: var(--text-muted); font-size: 1.25rem; font-weight: 500; display: block; }

    .btn-create-task {
        background: var(--accent-purple);
        color: white;
        padding: 0.8rem 1.75rem;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.95rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        box-shadow: 0 10px 20px rgba(91, 43, 130, 0.15);
        transition: all 0.3s ease;
    }

    .btn-create-task:hover {
        background: var(--accent-purple-light);
        transform: translateY(-2px);
        box-shadow: 0 15px 30px rgba(91, 43, 130, 0.25);
        color: white;
    }

    /* --- BOARD --- */
    .kanban-board {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
        align-items: flex-start;
    }

    .kanban-column {
        background: var(--column-bg);
        border-radius: 20px;
        padding: 1.25rem;
        min-height: 70vh;
        border: 1px solid rgba(226, 232, 240, 0.6);
    }

    .column-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        padding: 0 0.5rem;
    }

    .column-title h3 {
        font-size: 0.85rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--text-muted);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .column-dot { width: 8px; height: 8px; border-radius: 50%; }
    .dot-todo { background: var(--color-todo); box-shadow: 0 0 10px var(--color-todo); }
    .dot-doing { background: var(--color-doing); box-shadow: 0 0 10px var(--color-doing); }
    .dot-done { background: var(--color-done); box-shadow: 0 0 10px var(--color-done); }
    .dot-blocked { background: var(--color-blocked); box-shadow: 0 0 10px var(--color-blocked); }

    .task-count {
        background: rgba(255, 255, 255, 0.5);
        padding: 0.2rem 0.6rem;
        border-radius: 100px;
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--text-muted);
    }

    /* --- CARDS --- */
    .task-cards-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .kanban-card {
        background: var(--card-bg);
        border: 1px solid var(--card-border, #e2e8f0);
        border-radius: 16px;
        padding: 1.5rem;
        box-shadow: 0 4px 12px rgba(91, 43, 130, 0.03);
        transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
        position: relative;
        overflow: hidden;
    }

    .kanban-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(91, 43, 130, 0.08);
        border-color: var(--accent-purple-light);
    }

    .priority-indicator {
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 4px;
    }
    .prio-faible { background: #10b981; }
    .prio-moyenne { background: #f59e0b; }
    .prio-haute { background: #f97316; }
    .prio-urgente { background: #ef4444; }

    .card-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
    }

    .prio-label {
        font-size: 0.65rem;
        font-weight: 800;
        text-transform: uppercase;
        padding: 0.25rem 0.6rem;
        border-radius: 6px;
        background: #f1f5f9;
        color: var(--text-muted);
    }

    .card-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--text-main);
        margin-bottom: 0.5rem;
        line-height: 1.4;
    }

    .card-desc {
        font-size: 0.85rem;
        color: var(--text-muted);
        line-height: 1.5;
        margin-bottom: 1.5rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 1rem;
        border-top: 1px solid #f1f5f9;
    }

    .card-date {
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .card-actions {
        display: flex;
        gap: 0.5rem;
    }

    .action-circle {
        width: 32px; height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f8fafc;
        color: var(--text-muted);
        border: 1px solid #e2e8f0;
        transition: all 0.2s;
        text-decoration: none;
    }

    .action-circle:hover {
        background: var(--accent-purple);
        color: white;
        border-color: var(--accent-purple);
    }

    .delete-btn:hover { background: #ef4444; border-color: #ef4444; }

    .empty-col {
        text-align: center;
        padding: 2rem 1rem;
        border: 2px dashed rgba(148, 163, 184, 0.2);
        border-radius: 12px;
        color: #94a3b8;
        font-size: 0.8rem;
        font-weight: 500;
    }

    @media (max-width: 1200px) {
        .kanban-board { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 768px) {
        .kanban-board { grid-template-columns: 1fr; }
        .kanban-header { flex-direction: column; align-items: flex-start; }
    }
</style>
{% endblock %}

{% block body %}
<div class="kanban-wrapper">

    <div class="kanban-header">
        <div>
            <a href="{{ path('app_projet_employe_index') }}" class="back-btn">
                <i class="bi bi-arrow-left"></i> Retour aux projets
            </a>
            <h1>{{ projet.titre }}</h1>
        </div>
        <a href="{{ path('app_tache_new_pour_projet', {'projetId': projet.id}) }}" class="btn-create-task">
            <i class="bi bi-plus-circle"></i> Ajouter une tâche
        </a>
    </div>

    <div class="kanban-board">
        {# COLUMN: TO DO #}
        <div class="kanban-column">
            <div class="column-title">
                <h3><span class="column-dot dot-todo"></span> À Faire</h3>
                {% set todoItems = taches|filter(t => t.statut == 'a_faire') %}
                <span class="task-count">{{ todoItems|length }}</span>
            </div>
            <div class="task-cards-list">
                {% if todoItems is empty %}
                    <div class="empty-col">Libre de toute tâche</div>
                {% else %}
                    {% for tache in todoItems %}
                        <div class="kanban-card">
                            <div class="priority-indicator prio-{{ tache.level|lower }}"></div>
                            <div class="card-meta">
                                <span class="prio-label">{{ tache.level ?: 'Simple' }}</span>
                                <div class="card-actions">
                                    <a href="{{ path('app_tache_edit', {'id': tache.id}) }}" class="action-circle" title="Modifier">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_tache_delete', {'id': tache.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer cette tâche ?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tache.id) }}">
                                        <button class="action-circle delete-btn" title="Supprimer">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                            <h4 class="card-title">{{ tache.titre }}</h4>
                            <p class="card-desc">{{ tache.description ?: 'Traitement tactique en cours.' }}</p>
                            <div class="card-footer">
                                <div class="card-date">
                                    <i class="bi bi-calendar2-check"></i>
                                    {{ tache.dateFin ? tache.dateFin|date('d/m/Y') : '--/--/--' }}
                                </div>
                                <div style="font-size: 0.65rem; color: #cbd5e1; font-weight: 800;">OP-{{ tache.id }}</div>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>

        {# COLUMN: IN PROGRESS #}
        <div class="kanban-column">
            <div class="column-title">
                <h3><span class="column-dot dot-doing"></span> En Cours</h3>
                {% set doingItems = taches|filter(t => t.statut == 'en_cours') %}
                <span class="task-count">{{ doingItems|length }}</span>
            </div>
            <div class="task-cards-list">
                {% if doingItems is empty %}
                    <div class="empty-col">Rien n'est entamé</div>
                {% else %}
                    {% for tache in doingItems %}
                        <div class="kanban-card">
                            <div class="priority-indicator prio-{{ tache.level|lower }}"></div>
                            <div class="card-meta">
                                <span class="prio-label">{{ tache.level ?: 'Simple' }}</span>
                                <div class="card-actions">
                                    <a href="{{ path('app_tache_edit', {'id': tache.id}) }}" class="action-circle" title="Modifier">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_tache_delete', {'id': tache.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer cette tâche ?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tache.id) }}">
                                        <button class="action-circle delete-btn" title="Supprimer">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                            <h4 class="card-title">{{ tache.titre }}</h4>
                            <p class="card-desc">{{ tache.description ?: 'Traitement tactique en cours.' }}</p>
                            <div class="card-footer">
                                <div class="card-date">
                                    <i class="bi bi-calendar2-check"></i>
                                    {{ tache.dateFin ? tache.dateFin|date('d/m/Y') : '--/--/--' }}
                                </div>
                                <div style="font-size: 0.65rem; color: #cbd5e1; font-weight: 800;">OP-{{ tache.id }}</div>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>

        {# COLUMN: COMPLETED #}
        <div class="kanban-column">
            <div class="column-title">
                <h3><span class="column-dot dot-done"></span> Terminées</h3>
                {% set doneItems = taches|filter(t => t.statut == 'terminee') %}
                <span class="task-count">{{ doneItems|length }}</span>
            </div>
            <div class="task-cards-list">
                {% if doneItems is empty %}
                    <div class="empty-col">Zéro finalisé</div>
                {% else %}
                    {% for tache in doneItems %}
                        <div class="kanban-card">
                            <div class="priority-indicator prio-{{ tache.level|lower }}"></div>
                            <div class="card-meta">
                                <span class="prio-label">{{ tache.level ?: 'Simple' }}</span>
                                <div class="card-actions">
                                    <a href="{{ path('app_tache_edit', {'id': tache.id}) }}" class="action-circle" title="Modifier">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_tache_delete', {'id': tache.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer cette tâche ?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tache.id) }}">
                                        <button class="action-circle delete-btn" title="Supprimer">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                            <h4 class="card-title">{{ tache.titre }}</h4>
                            <p class="card-desc">{{ tache.description ?: 'Traitement tactique en cours.' }}</p>
                            <div class="card-footer">
                                <div class="card-date">
                                    <i class="bi bi-calendar2-check"></i>
                                    {{ tache.dateFin ? tache.dateFin|date('d/m/Y') : '--/--/--' }}
                                </div>
                                <div style="font-size: 0.65rem; color: #cbd5e1; font-weight: 800;">OP-{{ tache.id }}</div>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>

        {# COLUMN: BLOCKED #}
        <div class="kanban-column">
            <div class="column-title">
                <h3><span class="column-dot dot-blocked"></span> Bloquées</h3>
                {% set blockedItems = taches|filter(t => t.statut == 'bloquee') %}
                <span class="task-count">{{ blockedItems|length }}</span>
            </div>
            <div class="task-cards-list">
                {% if blockedItems is empty %}
                    <div class="empty-col">Aucun obstacle</div>
                {% else %}
                    {% for tache in blockedItems %}
                        <div class="kanban-card">
                            <div class="priority-indicator prio-{{ tache.level|lower }}"></div>
                            <div class="card-meta">
                                <span class="prio-label">{{ tache.level ?: 'Simple' }}</span>
                                <div class="card-actions">
                                    <a href="{{ path('app_tache_edit', {'id': tache.id}) }}" class="action-circle" title="Modifier">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_tache_delete', {'id': tache.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer cette tâche ?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tache.id) }}">
                                        <button class="action-circle delete-btn" title="Supprimer">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                            <h4 class="card-title">{{ tache.titre }}</h4>
                            <p class="card-desc">{{ tache.description ?: 'Traitement tactique en cours.' }}</p>
                            <div class="card-footer">
                                <div class="card-date">
                                    <i class="bi bi-calendar2-check"></i>
                                    {{ tache.dateFin ? tache.dateFin|date('d/m/Y') : '--/--/--' }}
                                </div>
                                <div style="font-size: 0.65rem; color: #cbd5e1; font-weight: 800;">OP-{{ tache.id }}</div>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>
    </div>

</div>
{% endblock %}