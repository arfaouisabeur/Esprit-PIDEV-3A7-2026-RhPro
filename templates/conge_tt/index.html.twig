<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function(){
  var p = {{ conge_tts|filter(c => c.statut == 'En attente')|length }};
  var a = {{ conge_tts|filter(c => c.statut == 'Accepté' or c.statut == 'approuvé')|length }};
  var r = {{ conge_tts|filter(c => c.statut == 'Refusé'  or c.statut == 'refusé')|length }};
  var t = p + a + r;

  document.getElementById('cg-pend').textContent  = p;
  document.getElementById('cg-ok').textContent    = a;
  document.getElementById('cg-no').textContent    = r;
  document.getElementById('cg-total').textContent = t;

  /* Ouvrir le modal */
  document.querySelectorAll('[data-open-stats-conge]').forEach(function(btn){
    btn.addEventListener('click', function(){
      document.getElementById('statsCongeModal').style.display='flex';
    });
  });

  /* Fermer sur fond */
  document.getElementById('statsCongeModal').addEventListener('click', function(e){
    if(e.target===this) this.style.display='none';
  });

  /* Chart.js camembert */
  new Chart(document.getElementById('congeChart').getContext('2d'), {
    type: 'doughnut',
    data: {
      labels: ['En attente','Approuvées','Refusées'],
      datasets:[{
        data:[p,a,r],
        backgroundColor:['#f59e0b','#10b981','#f43f5e'],
        borderColor:['#fff','#fff','#fff'],
        borderWidth:3,
        hoverOffset:12
      }]
    },
    options:{
      cutout:'62%',
      animation:{animateRotate:true,duration:900},
      plugins:{
        legend:{display:false},
        tooltip:{callbacks:{label:function(c){var pct=t>0?Math.round(c.parsed/t*100):0;return ' '+c.raw+' ('+pct+'%)';}}}
      }
    }
  });

  /* Ouvre en cliquant les boutons */
  document.querySelectorAll('[onclick*="statsCongeModal"]').forEach(function(btn){
    btn.addEventListener('click',function(){
      document.getElementById('statsCongeModal').style.display='flex';
    });
  });
})();
</script>

{# ══════════════════════════════════════════════════
   AJAX SEARCH — VUE EMPLOYÉ CONGÉS
══════════════════════════════════════════════════ #}
<script>
(function () {
  /* ── Références DOM ── */
  var form      = document.getElementById('em-cg-form');
  if (!form) return;                           // RH view → rien à faire

  var searchUrl  = form.getAttribute('data-search-url');
  var input      = form.querySelector('input[name="search"]');
  var selBy      = form.querySelector('select[name="searchBy"]');
  var selSort    = form.querySelector('select[name="sortBy"]');
  var dirInput   = document.getElementById('em-cg-sort-dir');
  var tbody      = document.getElementById('em-cg-tbody');
  var countNum   = document.getElementById('em-cg-count-num');
  var countBox   = document.getElementById('em-cg-count');
  var emptySearch = document.getElementById('em-cg-empty-state');   // "aucun résultat"
  var emptyData   = document.getElementById('em-cg-no-data');        // "aucune demande"

  if (!tbody) return;

  /* ── Spinner ── */
  function setLoading(on) {
    tbody.style.opacity = on ? '0.4' : '1';
    tbody.style.pointerEvents = on ? 'none' : '';
  }

  /* ── Badge statut ── */
  function buildBadge(statut) {
    var ok = (statut === 'Accepté' || statut === 'approuvé');
    var no = (statut === 'Refusé'  || statut === 'refusé');
    if (ok) return '<span class="badge b-accepted"><i class="fas fa-check" style="font-size:.7rem;"></i> Accepté</span>';
    if (no) return '<span class="badge b-rejected"><i class="fas fa-times" style="font-size:.7rem;"></i> Refusé</span>';
    return '<span class="badge b-pending"><i class="fas fa-hourglass-half" style="font-size:.7rem;"></i> En attente</span>';
  }

  /* ── Construction HTML d'une ligne ── */
  function buildRow(r, idx) {
    var duree = r.nbJours !== null
      ? '<span class="duree-badge">' + r.nbJours + ' j</span>'
      : '<span style="color:#94a3b8;">—</span>';

    var editBtn = r.editable
      ? '<a href="' + r.editUrl + '" class="btn-act btn-edit" title="Modifier"><i class="fas fa-pencil-alt"></i></a>'
      : '';

    var tr = document.createElement('tr');
    tr.style.animation = 'slideUp .3s cubic-bezier(.16,1,.3,1) ' + (idx * 0.04) + 's both';
    tr.innerHTML =
      '<td><strong style="color:#0f172a;font-family:\'Outfit\';font-size:1.05rem;">' + escHtml(r.typeConge) + '</strong></td>' +
      '<td>' +
        '<div style="font-weight:600;color:#0f172a;">' + escHtml(r.dateDebut) + '</div>' +
        '<div style="font-size:.85rem;color:#64748b;margin-top:2px;">au ' + escHtml(r.dateFin) + '</div>' +
      '</td>' +
      '<td>' + duree + '</td>' +
      '<td>' + buildBadge(r.statut) + '</td>' +
      '<td><div class="action-btns">' +
        '<a href="' + r.showUrl + '" class="btn-act btn-view" title="Afficher"><i class="fas fa-eye"></i></a>' +
        editBtn +
      '</div></td>';
    return tr;
  }

  /* ── Échappement HTML basique ── */
  function escHtml(str) {
    return String(str || '')
      .replace(/&/g,'&amp;').replace(/</g,'&lt;')
      .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  /* ── Mise à jour du tableau ── */
  function renderRows(rows) {
    tbody.innerHTML = '';
    if (rows.length === 0) {
      if (emptySearch)  { emptySearch.style.display = ''; }
      if (emptyData)    { emptyData.style.display   = 'none'; }
      if (countBox)     { countBox.style.display     = 'none'; }
    } else {
      if (emptySearch)  { emptySearch.style.display = 'none'; }
      if (emptyData)    { emptyData.style.display   = 'none'; }
      if (countBox)     { countBox.style.display     = ''; }
      rows.forEach(function (r, i) { tbody.appendChild(buildRow(r, i)); });
    }
    if (countNum) countNum.textContent = rows.length;
  }

  /* ── Appel AJAX principal ── */
  var _timer = null;
  function doSearch(immediate) {
    clearTimeout(_timer);
    _timer = setTimeout(function () {
      var params = new URLSearchParams({
        search:   input  ? input.value   : '',
        searchBy: selBy  ? selBy.value   : 'all',
        sortBy:   selSort ? selSort.value : 'id',
        sortDir:  dirInput ? dirInput.value : 'asc',
      });

      setLoading(true);

      fetch(searchUrl + '?' + params.toString(), {
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
      })
      .then(function (r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
      })
      .then(function (data) {
        setLoading(false);
        renderRows(data.rows || []);
      })
      .catch(function (err) {
        setLoading(false);
        console.error('[AJAX Congés]', err);
      });
    }, immediate ? 0 : 350);
  }

  /* ── Événements ── */

  // 1. Écriture en temps réel (debounce 350 ms)
  if (input) {
    input.addEventListener('input', function () { doSearch(false); });
  }

  // 2. Changement du critère de recherche ou de tri
  if (selBy)   selBy.addEventListener('change',   function () { doSearch(true); });
  if (selSort) selSort.addEventListener('change',  function () { doSearch(true); });

  // 3. Bouton ordre ASC/DESC (remplace l'onclick inline)
  var dirBtn = form.querySelector('.btn-dir');
  if (dirBtn && dirInput) {
    dirBtn.addEventListener('click', function (e) {
      e.preventDefault();
      var cur = dirInput.value === 'asc' ? 'desc' : 'asc';
      dirInput.value = cur;
      // Mettre à jour le label du bouton
      dirBtn.innerHTML = cur === 'asc'
        ? '<i class="fas fa-arrow-up-a-z"></i> Croissant'
        : '<i class="fas fa-arrow-down-z-a"></i> Décroissant';
      doSearch(true);
    });
  }

  // 4. Soumission du formulaire → AJAX au lieu de rechargement
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    doSearch(true);
  });

  // 5. Lien « Réinitialiser »
  var resetLink = form.querySelector('.btn-reset');
  if (resetLink) {
    resetLink.addEventListener('click', function (e) {
      e.preventDefault();
      if (input)    input.value    = '';
      if (selBy)    selBy.value    = 'all';
      if (selSort)  selSort.value  = 'id';
      if (dirInput) dirInput.value = 'asc';
      doSearch(true);
    });
  }

})();
</script>
{% endblock %}
