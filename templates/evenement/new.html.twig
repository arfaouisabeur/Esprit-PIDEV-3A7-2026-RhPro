{% extends 'base.html.twig' %}
{% block title %}Nouvel événement — RHPro{% endblock %}

{% block styles %}
:root { --green: #7c3aed; --green-dark: #6d28d9; --surface: #f5f0ff; --border: #e5e7eb; --text-dark: #111827; --text-muted: #6b7280; }
body { background: var(--surface); }
.form-page { min-height: 100vh; background: var(--surface); font-family: 'Inter', sans-serif; padding-bottom: 60px; }
.form-page-header { background: var(--surface); padding: 36px 0 0; }
.form-page-header-inner { max-width: 900px; margin: 0 auto; padding: 0 32px; display: flex; justify-content: space-between; align-items: center; gap: 20px; flex-wrap: wrap; }
.form-page-title { font-size: 26px; font-weight: 700; color: var(--green-dark); margin: 0 0 4px; }
.form-page-subtitle { font-size: 13px; color: var(--text-muted); margin: 0; }
.back-link { display: inline-flex; align-items: center; gap: 6px; color: var(--green-dark); font-size: 13px; font-weight: 500; text-decoration: none; }
.back-link:hover { text-decoration: underline; }
.form-card { background: #fff; border-radius: 16px; border: 1px solid var(--border); box-shadow: 0 2px 8px rgba(0,0,0,0.05); max-width: 900px; margin: 28px auto 0; padding: 32px; }
@media(max-width:640px){ .form-card { padding: 20px; margin: 16px; } }
.form-group { margin-bottom: 20px; }
.form-label { font-weight: 600; margin-bottom: 7px; display: block; font-size: 13px; color: #374151; }
.form-label .req { color: #ef4444; margin-left: 2px; }
.form-input { width: 100%; padding: 11px 14px; border-radius: 10px; border: 1.5px solid var(--border); background: #fafafa; font-size: 14px; box-sizing: border-box; transition: border-color .2s, box-shadow .2s; font-family: 'Inter', sans-serif; color: var(--text-dark); }
.form-input:focus { border-color: var(--green); background: #fff; outline: none; box-shadow: 0 0 0 3px rgba(124,58,237,.12); }
.form-input.is-invalid { border-color: #ef4444; background: #fff5f5; }
.form-input.is-invalid:focus { box-shadow: 0 0 0 3px rgba(239,68,68,.12); }
.form-input.date-input { cursor: pointer; caret-color: transparent; }
textarea.form-input { resize: vertical; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
@media(max-width:600px){ .form-row { grid-template-columns: 1fr; } }
.field-error { display: flex; align-items: center; gap: 5px; margin-top: 6px; font-size: 12px; color: #ef4444; font-weight: 500; }
.field-error svg { flex-shrink: 0; }
.form-alert { background: #fee2e2; border: 1px solid #fca5a5; border-radius: 10px; padding: 14px 16px; margin-bottom: 20px; display: flex; align-items: flex-start; gap: 10px; font-size: 13px; color: #991b1b; }
.form-alert svg { flex-shrink: 0; margin-top: 1px; }
.btn-submit { background: var(--green); color: #fff; padding: 13px 28px; border: none; border-radius: 12px; font-weight: 600; font-size: 15px; cursor: pointer; width: 100%; margin-top: 8px; transition: background .2s, transform .15s; font-family: 'Inter', sans-serif; }
.btn-submit:hover { background: var(--green-dark); transform: translateY(-1px); }
.date-wrapper { position: relative; }
.cal-popup { position: absolute; top: calc(100% + 6px); left: 0; z-index: 300; background: #fff; border: 1px solid #ddd; border-radius: 14px; box-shadow: 0 12px 32px rgba(0,0,0,0.16); padding: 14px; width: 280px; display: none; }
.cal-popup.open { display: block; }
.cal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
.cal-header span { font-weight: 700; font-size: 14px; color: #1f2937; }
.cal-nav { background: none; border: none; cursor: pointer; color: var(--green); font-size: 20px; padding: 2px 8px; border-radius: 6px; line-height: 1; }
.cal-nav:hover { background: #ede9fe; }
.cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; }
.cal-dname { text-align: center; font-size: 11px; font-weight: 700; color: #9ca3af; padding: 4px 0; text-transform: uppercase; }
.cal-day { text-align: center; padding: 7px 0; border-radius: 8px; font-size: 13px; cursor: pointer; color: #374151; transition: background .12s, color .12s; }
.cal-day:hover { background: #ede9fe; color: var(--green-dark); }
.cal-day.sel { background: var(--green); color: #fff; font-weight: 700; }
.cal-day.today { outline: 2px solid var(--green); color: var(--green-dark); font-weight: 600; }
.cal-day.empty { cursor: default; background: none !important; }
.img-preview { max-width: 200px; margin-top: 10px; border-radius: 10px; display: none; }
{% endblock %}

{% block body %}

<div class="form-page">
  <div class="form-page-header">
    <div class="form-page-header-inner">
      <div>
        <h1 class="form-page-title">📅 Nouvel événement</h1>
        <p class="form-page-subtitle">Remplissez le formulaire pour créer un événement</p>
      </div>
      <a href="{{ path('app_evenement_index') }}" class="back-link">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Retour aux événements
      </a>
    </div>
  </div>

  <div class="form-card">

    {% if form.vars.submitted and not form.vars.valid %}
    <div class="form-alert">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <div>Veuillez corriger les erreurs ci-dessous avant de valider.</div>
    </div>
    {% endif %}

    {{ form_start(form, {'attr': {'novalidate': true, 'id': 'new-ev-form'}}) }}

    <div class="form-group">
      <label class="form-label">Titre de l'événement <span class="req">*</span></label>
      {{ form_widget(form.titre, {'attr': {'class': 'form-input' ~ (form.titre.vars.errors|length > 0 ? ' is-invalid' : ''), 'placeholder': 'Ex: Séminaire annuel...'}}) }}
      {% for error in form.titre.vars.errors %}
        <div class="field-error"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/></svg>{{ error.message }}</div>
      {% endfor %}
    </div>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Date de début <span class="req">*</span></label>
        <div class="date-wrapper">
          <input type="text" id="ev_date_debut" name="evenement[date_debut]"
            class="form-input date-input {{ form.date_debut.vars.errors|length > 0 ? 'is-invalid' : '' }}"
            readonly autocomplete="off" onclick="toggleCal('start',event)"
            value="{{ form.date_debut.vars.value }}" placeholder="AAAA-MM-JJ">
          <div id="cal-start" class="cal-popup"></div>
        </div>
        {% for error in form.date_debut.vars.errors %}
          <div class="field-error"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/></svg>{{ error.message }}</div>
        {% endfor %}
      </div>
      <div class="form-group">
        <label class="form-label">Date de fin <span class="req">*</span></label>
        <div class="date-wrapper">
          <input type="text" id="ev_date_fin" name="evenement[date_fin]"
            class="form-input date-input {{ form.date_fin.vars.errors|length > 0 ? 'is-invalid' : '' }}"
            readonly autocomplete="off" onclick="toggleCal('end',event)"
            value="{{ form.date_fin.vars.value }}" placeholder="AAAA-MM-JJ">
          <div id="cal-end" class="cal-popup"></div>
        </div>
        {% for error in form.date_fin.vars.errors %}
          <div class="field-error"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/></svg>{{ error.message }}</div>
        {% endfor %}
      </div>
    </div>

    <div class="form-group">
      <label class="form-label">Lieu <span class="req">*</span></label>
      {{ form_widget(form.lieu, {'attr': {'class': 'form-input' ~ (form.lieu.vars.errors|length > 0 ? ' is-invalid' : ''), 'placeholder': 'Ex: Salle de conférence A...'}}) }}
      {% for error in form.lieu.vars.errors %}
        <div class="field-error"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/></svg>{{ error.message }}</div>
      {% endfor %}
    </div>

    <div class="form-group">
      <label class="form-label">Description</label>
      {{ form_widget(form.description, {'attr': {'class': 'form-input', 'rows': 4, 'placeholder': 'Décrivez cet événement...'}}) }}
    </div>

    <div class="form-group">
      <label class="form-label">URL de l'image (optionnel)</label>
      {{ form_widget(form.imageUrl, {'attr': {'class': 'form-input', 'id': 'ev_imageUrl', 'placeholder': 'https://...'}}) }}
      <img id="img-preview" class="img-preview">
    </div>

    {# ✅ FIX : type="submit" direct — suppression de rhConfirmAdd qui bypassait le token CSRF #}
    <button type="submit" class="btn-submit">
      💾 Créer l'événement
    </button>

    {% do form.date_debut.setRendered() %}
    {% do form.date_fin.setRendered() %}
    {{ form_end(form) }}
  </div>
</div>

<script>
const CS = {
  start: { id: 'ev_date_debut', pop: 'cal-start', y: null, m: null },
  end:   { id: 'ev_date_fin',   pop: 'cal-end',   y: null, m: null }
};
const MN = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
const DN = ['Di','Lu','Ma','Me','Je','Ve','Sa'];
function initState(k) {
  var s = CS[k], v = document.getElementById(s.id).value;
  if (v && /^\d{4}-\d{2}-\d{2}$/.test(v)) { var p = v.split('-'); s.y = +p[0]; s.m = +p[1]-1; }
  else { var n = new Date(); s.y = n.getFullYear(); s.m = n.getMonth(); }
}
function render(k) {
  var s = CS[k], sel = document.getElementById(s.id).value, now = new Date();
  var fd = new Date(s.y, s.m, 1).getDay(), td = new Date(s.y, s.m+1, 0).getDate();
  var h = '<div class="cal-header"><button type="button" class="cal-nav" onclick="nav(\''+k+'\',-1)">&#8249;</button><span>'+MN[s.m]+' '+s.y+'</span><button type="button" class="cal-nav" onclick="nav(\''+k+'\',1)">&#8250;</button></div><div class="cal-grid">';
  DN.forEach(function(d){ h += '<div class="cal-dname">'+d+'</div>'; });
  for (var i = 0; i < fd; i++) h += '<div class="cal-day empty"></div>';
  for (var d = 1; d <= td; d++) {
    var ds = s.y+'-'+String(s.m+1).padStart(2,'0')+'-'+String(d).padStart(2,'0');
    var c = 'cal-day';
    if (ds === sel) c += ' sel';
    if (d === now.getDate() && s.m === now.getMonth() && s.y === now.getFullYear()) c += ' today';
    h += '<div class="'+c+'" onclick="pick(\''+k+'\',\''+ds+'\')">'+d+'</div>';
  }
  document.getElementById(s.pop).innerHTML = h + '</div>';
}
function nav(k, delta) {
  CS[k].m += delta;
  if (CS[k].m > 11) { CS[k].m = 0; CS[k].y++; }
  if (CS[k].m < 0)  { CS[k].m = 11; CS[k].y--; }
  render(k);
}
function pick(k, ds) {
  var inp = document.getElementById(CS[k].id);
  inp.removeAttribute('readonly'); inp.value = ds; inp.setAttribute('readonly', true);
  closeAll();
}
function toggleCal(k, e) { e && e.stopPropagation(); var pop = document.getElementById(CS[k].pop), isOpen = pop.classList.contains('open'); closeAll(); if (!isOpen) { initState(k); render(k); pop.classList.add('open'); } }
function closeAll() { document.querySelectorAll('.cal-popup').forEach(function(p){ p.classList.remove('open'); }); }
document.addEventListener('click', function(e){ if (!e.target.closest('.date-wrapper')) closeAll(); });
document.addEventListener('DOMContentLoaded', function(){
  var inp = document.getElementById('ev_imageUrl'), img = document.getElementById('img-preview');
  if (inp) inp.addEventListener('input', function(){ img.src = this.value; img.style.display = this.value ? 'block' : 'none'; });
});
</script>
{% endblock %}
